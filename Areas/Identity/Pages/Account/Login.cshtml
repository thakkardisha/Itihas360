@page
@model LoginModel
@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Itihas 360 - Login</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/itihas-auth.css" asp-append-version="true" />
</head>
<body class="auth-body">

    <div class="auth-card">
        <div class="auth-header">
            <a class="nav-brand" href="/">
                <div class="nav-brand-icon"><i class="fa-solid fa-scroll"></i></div>
                <div class="text-start">
                    <div>Itihas 360</div>
                    <span class="nav-brand-sub">Archive Management</span>
                </div>
            </a>
            <div class="brand-line"></div>
        </div>

        <form id="account" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>

            <div class="auth-form-group">
                <label asp-for="Input.Email">Email</label>
                <input asp-for="Input.Email" class="auth-input" autocomplete="username" />
                <span asp-validation-for="Input.Email" class="text-danger small d-block mt-1"></span>
            </div>

            <div class="auth-form-group">
                <label asp-for="Input.Password">Password</label>
                <input asp-for="Input.Password" class="auth-input" autocomplete="current-password" />
                <span asp-validation-for="Input.Password" class="text-danger small d-block mt-1"></span>
            </div>

            <div class="auth-links-block align-items-start mt-3">
                <div class="form-check">
                    <input class="form-check-input" asp-for="Input.RememberMe" />
                    <label class="form-check-label small text-muted-parch" asp-for="Input.RememberMe">Remember Me</label>
                </div>
                <div>
                    <a asp-page="./ForgotPassword" class="small">Forgot password?</a>
                </div>
            </div>

            <button type="submit" class="btn btn-itihas w-100">Login</button>
        </form>

        <div class="auth-footer">
            <p class="text-muted-parch mb-1">New User? <a asp-page="./Register">Register</a></p>
            <p class="mb-0"><a asp-page="./ResendEmailConfirmation" class="small fw-normal">Resend email confirmation</a></p>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>