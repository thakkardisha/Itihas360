@page
@model LoginModel
@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Itihas360 - Admin Access</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/itihas-auth.css" asp-append-version="true" />
</head>
<body class="auth-body">

    <div class="auth-card">
        <div class="auth-header">
            <h1>ITIHAS 360</h1>
            <div class="brand-line"></div>
        </div>

        <form id="account" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>

            <div class="form-floating mb-3">
                <input asp-for="Input.Email" class="form-control" autocomplete="username" placeholder="Email" />
                <label asp-for="Input.Email">Email</label>
                <span asp-validation-for="Input.Email" class="text-danger small"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Input.Password" class="form-control" autocomplete="current-password" placeholder="Password" />
                <label asp-for="Input.Password">Password</label>
                <span asp-validation-for="Input.Password" class="text-danger small"></span>
            </div>

            <div class="d-flex justify-content-between align-items-center mb-4">
                <div class="form-check">
                    <input class="form-check-input" asp-for="Input.RememberMe" />
                    <label class="form-check-label small text-muted" asp-for="Input.RememberMe">Remember device</label>
                </div>
                <a asp-page="./ForgotPassword" class="small text-muted text-decoration-none">Forgot password?</a>
            </div>

            <button type="submit" class="btn btn-itihas w-100">Login</button>
        </form>

        <div class="auth-footer">
            <p class="text-muted mb-1">New user? <a asp-page="./Register">Register</a></p>
            <p class="mb-0"><a asp-page="./ResendEmailConfirmation" class="text-muted small fw-normal">Resend confirmation</a></p>
        </div>
    </div>

    <partial name="_ValidationScriptsPartial" />
    @* Existing JWT script can go here *@
</body>
</html>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const loginForm = document.getElementById('account');

            loginForm.addEventListener('submit', async function (e) {
                // 1. Get the credentials from the input fields
                const emailInput = document.querySelector('input[autocomplete="username"]');
                const passwordInput = document.querySelector('input[autocomplete="current-password"]');

                if (emailInput && passwordInput) {
                    try {
                        // 2. Call your API to get the JWT Token
                        const response = await fetch('/api/Authenticate/login', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({
                                email: emailInput.value,
                                password: passwordInput.value
                            })
                        });

                        const data = await response.json();

                        if (response.ok && data.token) {
                            // 3. Save the token for the Admin Dashboard
                            localStorage.setItem("token", data.token);
                            console.log("Admin Token stored successfully.");
                        }
                    } catch (err) {
                        console.error("JWT Sync Failed: ", err);
                    }
                }
                // We do NOT call e.preventDefault() here.
                // We want the form to continue to the server so the Identity Cookie is set.
            });
        });
    </script>
}
