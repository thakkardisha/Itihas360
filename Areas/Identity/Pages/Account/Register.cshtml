@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
    Layout = null; // Maintains consistency by removing global header/footer
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Itihas360 - Create Account</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/itihas-auth.css" asp-append-version="true" />
</head>
<body class="auth-body">

    <div class="auth-card">
        <div class="auth-header">
            <h1>ITIHAS 360</h1>
            <div class="brand-line"></div>
        </div>

        <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>

            <div class="form-floating mb-3">
                <input asp-for="Input.Email" class="form-control" autocomplete="username" placeholder="Email" />
                <label asp-for="Input.Email">Email</label>
                <span asp-validation-for="Input.Email" class="text-danger small"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Input.Password" class="form-control" autocomplete="new-password" placeholder="Password" />
                <label asp-for="Input.Password">Password</label>
                <span asp-validation-for="Input.Password" class="text-danger small"></span>
            </div>

            <div class="form-floating mb-4">
                <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" placeholder="Confirm Password" />
                <label asp-for="Input.ConfirmPassword">Confirm Password</label>
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
            </div>

            <button id="registerSubmit" type="submit" class="btn btn-itihas w-100">Create Account</button>
        </form>

        @if ((Model.ExternalLogins?.Count ?? 0) > 0)
        {
            <div class="text-center mt-3">
                <p class="text-muted small">Or join with</p>
                <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                    @foreach (var provider in Model.ExternalLogins!)
                    {
                        <button type="submit" class="btn btn-outline-secondary btn-sm" name="provider" value="@provider.Name">
                            @provider.DisplayName
                        </button>
                    }
                </form>
            </div>
        }

        <div class="auth-footer">
            <p class="text-muted mb-0">Already have an account? <a asp-page="./Login">Login</a></p>
        </div>
    </div>

    <partial name="_ValidationScriptsPartial" />
</body>
</html>