@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Itihas 360 - Register</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/itihas-auth.css" asp-append-version="true" />
</head>
<body class="auth-body">

    <div class="auth-card">
        <div class="auth-header">
            <a class="nav-brand" href="/">
                <div class="nav-brand-icon"><i class="fa-solid fa-scroll"></i></div>
                <div class="text-start">
                    <div>Itihas 360</div>
                    <span class="nav-brand-sub">Archive Management</span>
                </div>
            </a>
            <div class="brand-line"></div>
        </div>

        <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>

            <div class="auth-form-group">
                <label asp-for="Input.Email">Email</label>
                <input asp-for="Input.Email" class="auth-input" autocomplete="username" />
                <span asp-validation-for="Input.Email" class="text-danger small d-block mt-1"></span>
            </div>

            <div class="auth-form-group">
                <label asp-for="Input.Password">Password</label>
                <input asp-for="Input.Password" class="auth-input" autocomplete="new-password" />
                <span asp-validation-for="Input.Password" class="text-danger small d-block mt-1"></span>
            </div>

            <div class="auth-form-group mb-4">
                <label asp-for="Input.ConfirmPassword">Confirm Password</label>
                <input asp-for="Input.ConfirmPassword" class="auth-input" autocomplete="new-password" />
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger small d-block mt-1"></span>
            </div>

            <button id="registerSubmit" type="submit" class="btn btn-itihas w-100">Register</button>
        </form>

        @if ((Model.ExternalLogins?.Count ?? 0) > 0)
        {
            <div class="text-center mt-4 pt-3 border-top border-secondary border-opacity-15">
                <p class="text-muted-parch small mb-2">Or register with</p>
                <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                    <div class="d-flex gap-2 justify-content-center">
                        @foreach (var provider in Model.ExternalLogins!)
                        {
                            <button type="submit" class="btn btn-outline-secondary btn-sm px-3" name="provider" value="@provider.Name">
                                @provider.DisplayName
                            </button>
                        }
                    </div>
                </form>
            </div>
        }

        <div class="auth-footer">
            <p class="text-muted-parch mb-0">Already have an account? <a href="./Login">Login</a></p>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>