<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Itihas 360 — A complete view of world history, civilisations and cultures." />
    <title>@ViewData["Title"] — Itihas 360</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/global.css" asp-append-version="true" />
    <style>
        /* Fix for Navbar background color and toggle structure when collapsed on mobile devices */
        #navMenu {
            transition: background-color 0.3s ease;
        }

        @@media (max-width: 991.98px) {
            #navMenu.collapse.show, #navMenu.collapsing {
                background-color: var(--ink) !important;
                padding: 1.25rem;
                border-radius: 6px;
                border: 1px solid var(--border-lt);
                margin-top: 0.75rem;
                display: block !important;
            }
        }

        /* Explicit layer alignment fix for custom Notification Overlay panel */
        #notifPanel {
            position: fixed;
            top: 75px;
            right: -400px;
            width: 350px;
            max-width: 90vw;
            height: auto;
            max-height: 80vh;
            background-color: var(--ink-2);
            border: 1px solid var(--border-lt);
            box-shadow: 0 8px 30px rgba(0, 0, 0, 0.5);
            z-index: 1060;
            transition: right 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            display: flex;
            flex-direction: column;
        }

        #notifPanel.active {
            right: 20px;
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <div id="searchOverlay" role="dialog" aria-modal="true" aria-label="Search">
        <div class="search-wrap">
            <div class="search-inner">
                <i class="fa fa-search" style="color:var(--gold);font-size:1.3rem;flex-shrink:0;"></i>
                <form id="searchForm" action="/articles" method="get" class="w-100 m-0 d-flex align-items-center">
                    <input type="text" id="searchInput" name="search" placeholder="Search the articles and hit enter…" autocomplete="off" class="bg-transparent border-0 w-100 text-white ms-2" style="outline: none;" />
                </form>
                <button class="search-close-btn" id="searchClose"><i class="fa fa-times"></i></button>
            </div>
        </div>
    </div>

    <nav id="mainNav" class="navbar navbar-expand-lg">
        <div class="container">
            <a class="navbar-brand nav-brand" href="/">
                <div class="nav-brand-icon"><i class="fa-solid fa-scroll"></i></div>
                <div>
                    Itihas 360
                    <span class="nav-brand-sub">A Complete View of History</span>
                </div>
            </a>

            <button class="navbar-toggler border-0" type="button"
                    data-bs-toggle="collapse" data-bs-target="#navMenu"
                    aria-controls="navMenu" aria-expanded="false" aria-label="Toggle navigation"
                    style="color:var(--gold);">
                <i class="fa fa-bars"></i>
            </button>

            <div class="collapse navbar-collapse" id="navMenu">
                <ul class="navbar-nav mx-auto gap-1">
                    <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="/articles">Articles</a></li>
                    <li class="nav-item"><a class="nav-link" href="/timeline">Timeline</a></li>
                    <li class="nav-item"><a class="nav-link" href="/personalities">Personalities</a></li>
                    <li class="nav-item"><a class="nav-link" href="/categories">Categories</a></li>
                    <li class="nav-item"><a class="nav-link" href="/quiz">Quiz</a></li>
                    <li class="nav-item"><a class="nav-link" href="/about">About</a></li>
                </ul>
                <div class="d-flex align-items-center gap-2 mt-2 mt-lg-0">
                    <button class="nav-notif-btn" id="notifToggle" title="Recent Dispatches" aria-label="Notifications">
                        <i class="fa fa-bell" style="font-size:.85rem;"></i>
                        <span class="notif-dot visible" id="notifDot"></span>
                    </button>
                    <button class="nav-search-btn" id="searchOpenTrigger">
                        <i class="fa fa-search"></i> Search
                    </button>
                </div>
            </div>
        </div>
    </nav>

    @RenderBody()

    <button id="scrollTop" title="Scroll to Top"><i class="fa fa-chevron-up"></i></button>

    <footer id="footer" class="py-5">
        <div class="container">
            <div class="row g-5">
                <div class="col-lg-4 col-md-6">
                    <div class="footer-brand mb-3">
                        @if (ViewData["OrgPhoto"] != null)
                        {
                            <img src="@ViewData["OrgPhoto"]" alt="Logo" style="height:30px;" class="me-2" />
                        }
                        <span class="h5 text-uppercase tracking-wider">@(ViewData["OrgName"] ?? "Itihas 360")</span>
                    </div>
                    <p class="footer-bio small opacity-75 mb-3">
                        @(ViewData["OrgAddress"] ?? "Exploring human history, ancient civilizations, and historical global archives.")
                    </p>
                </div>

                <div class="col-lg-4 col-md-6">
                    <h6 class="text-uppercase tracking-wider text-white mb-3" style="font-size: 0.85rem; font-family: var(--font-display);">Quick Links</h6>
                    <div class="row">
                        <div class="col-6">
                            <ul class="list-unstyled footer-links small">
                                <li class="mb-2"><a href="/" class="text-decoration-none opacity-75 text-white">Home</a></li>
                                <li class="mb-2"><a href="/articles" class="text-decoration-none opacity-75 text-white">Articles</a></li>
                                <li class="mb-2"><a href="/timeline" class="text-decoration-none opacity-75 text-white">Timeline</a></li>
                            </ul>
                        </div>
                        <div class="col-6">
                            <ul class="list-unstyled footer-links small">
                                <li class="mb-2"><a href="/categories" class="text-decoration-none opacity-75 text-white">Categories</a></li>
                                <li class="mb-2"><a href="/quiz" class="text-decoration-none opacity-75 text-white">Interactive Quiz</a></li>
                                <li class="mb-2"><a href="/about" class="text-decoration-none opacity-75 text-white">About Us</a></li>
                            </ul>
                        </div>
                    </div>
                </div>

                <div class="col-lg-4 col-md-12">
                    <h6 class="text-uppercase tracking-wider text-white mb-3" style="font-size: 0.85rem; font-family: var(--font-display);">Subscribe to Dispatches</h6>
                    <p class="small opacity-75 mb-3">Receive weekly scholarly history articles directly to your inbox.</p>
                    <form id="newsletterForm" class="d-flex gap-2">
                        <input type="email" class="form-control form-control-sm bg-transparent border-secondary text-white" placeholder="Enter your email addresses..." required style="outline:none; box-shadow:none;" />
                        <button type="submit" class="btn btn-sm btn-outline-warning text-uppercase px-3" style="font-size:0.7rem; letter-spacing:0.1em;">Join</button>
                    </form>
                </div>
            </div>

            <hr class="my-4 opacity-10" style="border-color: var(--border-lt);">
            
            <div class="footer-bottom d-flex justify-content-between align-items-center flex-wrap gap-2">
                <span class="small opacity-50">&copy; @DateTime.Now.Year Itihas 360 &nbsp;&middot;&nbsp; All rights reserved</span>
                <span class="small opacity-50">Designed with precision</span>
            </div>
        </div>
    </footer>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>