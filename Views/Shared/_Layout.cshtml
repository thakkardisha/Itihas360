@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@{
    var organization = ViewBag.Organization;
    var categories = ViewBag.Categories as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
    var latestArticles = ViewBag.LatestArticles as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="@(ViewData["Description"] ?? "Itihas 360 — A complete view of world history, civilisations and cultures.")" />
    <title>@(ViewData["Title"] ?? "Itihas 360")</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/global.css" />
    <style>
        body {
            overflow-x: hidden;
        }

        #navMenu {
            transition: background-color 0.3s ease;
        }

        @@media (max-width: 991.98px) {
            #navMenu.collapse.show, #navMenu.collapsing {
                background-color: var(--ink) !important;
                padding: 1.25rem;
                border-radius: 6px;
                border: 1px solid var(--border-lt);
                margin-top: 0.75rem;
                display: block !important;
            }
        }


    </style>
    @await RenderSectionAsync("HeadStyles", required: false)
</head>
<body>

    <div id="searchOverlay" role="dialog" aria-modal="true" aria-label="Search">
        <div class="search-wrap">
            <div class="search-inner">
                <i class="fa fa-search" style="color:var(--gold);font-size:1.3rem;flex-shrink:0;"></i>
                <form id="searchForm" action="/articles" method="get" class="w-100 m-0 d-flex align-items-center">
                    <input type="text" id="searchInput" name="search" placeholder="Search the articles and hit enter…" autocomplete="off" class="bg-transparent border-0 w-100 text-white ms-2" style="outline: none;" />
                </form>
                <button class="search-close-btn" id="searchClose"><i class="fa fa-times"></i></button>
            </div>
            <div class="search-tags mt-3">
                <span class="search-tag-label me-1">Categories ·</span>
                @foreach (var cat in categories.Take(6))
                {
                    <span class="search-tag" style="cursor:pointer;" onclick="redirectToCategory('@cat.Category.CategorySlug')">
                        @cat.Category.CategoryName
                    </span>
                }
            </div>
        </div>
    </div>

    <div id="notifPanel" role="dialog" aria-label="Notifications">
        <div class="notif-panel-header d-flex justify-content-between align-items-center p-3" style="border-bottom: 1px solid var(--border-lt);">
            <span class="notif-panel-title text-white">
                <i class="fa fa-scroll me-2" style="font-size:.7rem; color: var(--gold);"></i>Recent Articles
            </span>
            <button class="notif-panel-close bg-transparent border-0 text-white opacity-75" id="notifClose"><i class="fa fa-times"></i></button>
        </div>

        <div class="notif-panel-body p-2" style="overflow-y: auto;">
            @{
                var notifList = latestArticles.ToList();
            }
            @if (!notifList.Any())
            {
                <div class="notif-empty text-center py-4 opacity-50 text-white">No articles published yet.</div>
            }
            else
            {
                foreach (var article in notifList.Take(5))
                {
                    <div class="notif-item p-2 mb-1 rounded text-white"
                         onclick="window.location.href='/article/@article.Slug'"
                         style="cursor:pointer;">
                        <div class="d-flex align-items-start gap-2">
                            <div class="notif-item-icon mt-1" style="color: var(--gold);"><i class="fa fa-feather-alt"></i></div>
                            <div class="notif-item-content">
                                <div class="notif-item-title small" style="font-weight: 600;">@article.Title</div>
                                <div class="notif-item-time opacity-50" style="font-size: 0.7rem;">
                                    <i class="fa fa-calendar-alt me-1"></i>@(article.CreatedAt?.ToString("dd MMM yyyy") ?? "Recent")
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>

        <div class="notif-panel-footer p-3 text-center" style="border-top: 1px solid var(--border-lt);">
            <a href="/articles" class="small text-decoration-none" style="color: var(--gold);">View all articles &rarr;</a>
        </div>
    </div>

    <nav id="mainNav" class="navbar navbar-expand-lg">
        <div class="container">
            <a class="navbar-brand nav-brand" href="/">
                <div class="nav-brand-icon"><i class="fa-solid fa-scroll"></i></div>
                <div>
                    Itihas 360                    
                </div>
            </a>

            <button class="navbar-toggler border-0" type="button"
                    data-bs-toggle="collapse" data-bs-target="#navMenu"
                    aria-controls="navMenu" aria-expanded="false" aria-label="Toggle navigation"
                    style="color:var(--gold);">
                <i class="fa fa-bars"></i>
            </button>

            <div class="collapse navbar-collapse" id="navMenu">
                <ul class="navbar-nav mx-auto gap-1">
                    <li class="nav-item"><a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Home" ? "active" : "")" href="/">Home</a></li>
                    <li class="nav-item"><a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Articles" ? "active" : "")" href="/articles">Articles</a></li>
                    <li class="nav-item"><a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Timeline" ? "active" : "")" href="/timeline">Timeline</a></li>
                    
                    <li class="nav-item dropdown custom-category-dropdown">
                        <a class="nav-link dropdown-toggle @(ViewData["ActivePage"]?.ToString() == "Categories" ? "active" : "")" 
                           href="#" 
                           id="categoriesDropdown" 
                           role="button" 
                           data-bs-toggle="dropdown" 
                           aria-expanded="false">
                            Categories
                        </a>
                        <ul class="dropdown-menu border-0 shadow" aria-labelledby="categoriesDropdown">
                            @if (categories != null && categories.Any())
                            {
                                foreach (var cat in categories)
                                {
                                    <li>
                                        <a class="dropdown-item" href="/Articles?category=@cat.Category.CategorySlug">
                                            <i class="fa fa-bookmark dropdown-gold-icon me-2"></i>@cat.Category.CategoryName
                                        </a>
                                    </li>
                                }
                            }
                            else
                            {
                                <li><span class="dropdown-item text-muted small">No categories found</span></li>
                            }
                        </ul>
                    </li>

                    <li class="nav-item"><a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Quiz" ? "active" : "")" href="/quiz">Quiz</a></li>
                    <li class="nav-item"><a class="nav-link" href="#" id="liveNewsToggleBtn"><i class="fa fa-circle text-danger me-1 live-pulse-dot"></i>Live News</a></li>
                </ul>
                <div class="d-flex align-items-center gap-2 mt-2 mt-lg-0">
                    @{
                        var unreadCount = ViewBag.UnreadNotifCount as int? ?? 0;
                        bool showDot = unreadCount > 0;
                    }

                    <button class="nav-notif-btn" type="button" id="notifToggle" data-count="@unreadCount" title="Recent Articles" aria-label="Notifications">
                        <i class="fa fa-bell" style="font-size:.85rem;"></i>
                        <span class="notif-dot @(showDot ? "visible" : "")" id="notifDot"></span>
                    </button>

                    <button class="nav-search-btn" type="button" id="searchOpenTrigger">
                        <i class="fa fa-search"></i> Search
                    </button>
                </div>
            </div>
        </div>
    </nav>

    @RenderBody()

    <footer id="footer" class="py-5">
        <div class="container">
            <div class="row g-5">

                <div class="col-lg-5 col-md-12">
                    <div class="footer-brand-wrapper mb-3">
                        @if (!string.IsNullOrEmpty(organization?.OrganizationPhoto))
                        {
                            <img src="@organization.OrganizationPhoto" alt="Logo" class="footer-logo mb-2" />
                        }
                        else
                        {
                            <div class="footer-logo-fallback mb-2">
                                <i class="fa-solid fa-scroll"></i>
                            </div>
                        }
                        
                    </div>

                    <div class="footer-bio mb-3">
                        @(organization?.CompanyAddress), @(organization?.City), @(organization?.State)
                    </div>

                    <div class="footer-contact mb-4">
                        <div><i class="fa fa-envelope me-2 opacity-70"></i> @(organization?.Email)</div>
                        <div><i class="fa fa-phone me-2 opacity-70"></i> +91 @(organization?.Mobile)</div>
                    </div>

                    <div class="footer-socials">
                        <a href="@organization?.X" aria-label="X (Twitter)"><i class="fab fa-x-twitter"></i></a>
                        <a href="@organization?.Instagram" aria-label="Instagram"><i class="fab fa-instagram"></i></a>
                        <a href="@organization?.LinkedIn" aria-label="LinkedIn"><i class="fab fa-linkedin-in"></i></a>
                        <a href="@organization?.Facebook" aria-label="Facebook"><i class="fab fa-facebook"></i></a>
                    </div>
                </div>

                <div class="col-lg-3 col-md-6">
                    <h6 class="footer-heading">Navigation</h6>
                    <ul class="footer-links">
                        <li><a href="/">Home</a></li>
                        <li><a href="/articles">Articles</a></li>
                        <li><a href="/timeline">Timeline</a></li>
                        <li><a href="/about">About Us</a></li>
                        <li><a href="/contact">Contact Us</a></li>
                    </ul>
                </div>

                <div class="col-lg-4 col-md-6">
                    <h6 class="footer-heading">Stay in the Loop</h6>
                    <div class="footer-newsletter-text mb-3">
                        Join the inner circle for weekly dispatches from the archives.
                    </div>
                    <form id="newsletterForm" action="/Home/SubscribeNewsletter" method="post" class="mb-4">
                        <div class="footer-newsletter">
                            <input type="email" name="email" id="newsletterEmail" placeholder="Email address" required autocomplete="off" />
                            <button type="submit" id="newsletterSubmitBtn" aria-label="Subscribe"><i class="fa fa-paper-plane"></i></button>
                        </div>
                        <small id="newsletterStatus" class="d-block mt-2" style="display: none; font-size:0.9rem; letter-spacing: 0.05em;"></small>
                    </form>
                    <h6 class="footer-heading">Resources</h6>
                    <ul class="footer-links">
                        <li><a href="/quiz">History Quiz</a></li>
                    </ul>
                </div>

            </div>

            <hr class="my-4 opacity-10" style="border-color: var(--gold);" />

            <div class="footer-bottom d-flex justify-content-between align-items-center">
                <span class="footer-copyright">&copy; @DateTime.Now.Year ITIHAS 360 &nbsp;&middot;&nbsp; ALL RIGHTS RESERVED</span>
            </div>
        </div>
    </footer>

    <div class="news-modal-overlay" id="newsModalOverlay">
        <div class="news-modal-container">
            <button class="news-modal-close-btn" id="closeNewsModal">&times;</button>
            
            @if (ViewBag.LiveNewsFeed != null && ((List<Itihas360.Models.NewsFeedCache>)ViewBag.LiveNewsFeed).Any())
            {
                var newsList = (List<Itihas360.Models.NewsFeedCache>)ViewBag.LiveNewsFeed;
                
                <div id="newsCarousel" class="carousel slide h-100" data-bs-ride="false">
                    <div class="carousel-inner h-100">
                        @for (int i = 0; i < newsList.Count; i++)
                        {
                            <div class="carousel-item h-100 @(i == 0 ? "active" : "")">
                                <div class="news-slide-bg" style="background: linear-gradient(rgba(0,0,0,0.1), rgba(0,0,0,0.4), rgba(0,0,0,0.95)), url('@newsList[i].ImageUrl') center/cover no-repeat;">
                                    <div class="news-text-content">
                                        <div class="d-flex align-items-center gap-2 mb-2">
                                            <span class="badge bg-danger text-uppercase tracking-wider rounded-1 px-2" style="font-size:0.65rem; font-weight:600; letter-spacing:0.05em;">LIVE FEED</span>
                                            @if (!string.IsNullOrEmpty(newsList[i].SourceName))
                                            {
                                                <span class="text-white-50 small font-monospace"><i class="fa fa-newspaper-o me-1"></i>@newsList[i].SourceName</span>
                                            @if (newsList[i].SourceName != null) {}
                                            }
                                        </div>
                                        <h2 class="news-slide-title">@newsList[i].Headline</h2>
                                        <p class="news-slide-desc d-none d-md-block">@newsList[i].Summary</p>

                                        <a href="@Url.Action("News", "Home", new { id = newsList[i].NewsCacheId })"
                                           class="btn btn-sm btn-outline-light mt-3 rounded-0 px-3"
                                           style="font-size:0.85rem; letter-spacing:0.05em;">
                                             Read Full Report <i class="fa fa-arrow-right ms-1 small"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    <button class="carousel-control-prev" type="button" data-bs-target="#newsCarousel" data-bs-slide="prev">
                        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Previous</span>
                    </button>
                    <button class="carousel-control-next" type="button" data-bs-target="#newsCarousel" data-bs-slide="next">
                        <span class="carousel-control-next-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Next</span>
                    </button>
                </div>
            }
            else
            {
                <div class="d-flex flex-column align-items-center justify-content-center h-100 text-white p-4">
                    <i class="fa fa-refresh fa-spin mb-3" style="font-size: 2.2rem; color: var(--gold, #a07820);"></i>
                    <h5 style="font-family: var(--font-display, serif); color: #fff; letter-spacing:0.03em;">Synchronizing Live Feed</h5>
                    <p class="text-muted small">Fetching fresh global dispatches. Please wait...</p>
                </div>
            }
        </div>
    </div>

    <button id="scrollTop" aria-label="Scroll to top"><i class="fa fa-chevron-up"></i></button>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // ── 1. NEWSLETTER MECHANICS ──
            const form = document.getElementById("newsletterForm");
            const statusMsg = document.getElementById("newsletterStatus");
            const inputField = document.getElementById("newsletterEmail");

            if (form) {
                form.addEventListener("submit", function (e) {
                    e.preventDefault();
                    const emailValue = inputField.value;
                    const formData = new FormData();
                    formData.append("email", emailValue);

                    fetch(form.getAttribute("action"), {
                        method: "POST",
                        body: formData,
                        headers: { 'X-Requested-With': 'XMLHttpRequest' }
                    })
                    .then(response => response.json())
                    .then(data => {
                        statusMsg.style.display = "block";
                        statusMsg.textContent = data.message;
                        if (data.success) {
                            statusMsg.className = "d-block mt-2 newsletter-success-text";
                            inputField.value = "";
                        } else {
                            statusMsg.className = "d-block mt-2 newsletter-error-text";
                        }
                        setTimeout(() => { statusMsg.style.display = "none"; }, 5000);
                    })
                    .catch(error => {
                        statusMsg.style.display = "block";
                        statusMsg.className = "d-block mt-2 newsletter-error-text";
                        statusMsg.textContent = "Something went wrong. Please try again.";
                    });
                });
            }

            // ── 2. LIVE NEWS CAROUSEL SYSTEM (8-Second Intervals) ──
            const openNewsBtn = document.getElementById("liveNewsToggleBtn");
            const closeNewsBtn = document.getElementById("closeNewsModal");
            const newsOverlay = document.getElementById("newsModalOverlay");
            let newsCycleTimer = null;
            const cycleDuration = 8000; 

            function startNewsTimer() {
                const carouselEl = document.getElementById('newsCarousel');
                if (carouselEl) {
                    const carouselInstance = bootstrap.Carousel.getOrCreateInstance(carouselEl);
                    newsCycleTimer = setInterval(() => {
                        carouselInstance.next();
                    }, cycleDuration);
                }
            }

            function stopNewsTimer() {
                if (newsCycleTimer) {
                    clearInterval(newsCycleTimer);
                    newsCycleTimer = null;
                }
            }

            if (openNewsBtn && newsOverlay) {
                openNewsBtn.addEventListener("click", function (e) {
                    e.preventDefault();
                    newsOverlay.classList.add("active");
                    document.body.style.overflow = "hidden";
                    
                    const carouselEl = document.getElementById('newsCarousel');
                    if (carouselEl) {
                        const carouselInstance = bootstrap.Carousel.getOrCreateInstance(carouselEl);
                        carouselInstance.to(0);
                    }
                    startNewsTimer();
                });
            }

            if (closeNewsBtn && newsOverlay) {
                closeNewsBtn.addEventListener("click", <li class="nav-item dropdown custom-category-dropdown">
                    <a class="nav-link dropdown-toggle @(ViewData["ActivePage"]?.ToString() == "Categories" ? "active" : "")"
                        href="#"
                        id="categoriesDropdown"
                        role="button"
                        aria-expanded="false">
                        Categories
                    </a>
                    <ul class="dropdown-menu" aria-labelledby="categoriesDropdown">
        @if (categories != null && categories.Any())
        {
            foreach (var cat in categories)
            {
                                <li>
                                    <a class="dropdown-item" href="/Articles?category=@cat.Category.CategorySlug">
                                        <i class="fa-solid fa-book-open dropdown-gold-icon me-2"></i>@cat.Category.CategoryName
                                    </a>
                                </li>
            }
        }
        else
        {
                            <li><span class="dropdown-item text-muted small">No categories found</span></li>
        }
                    </ul>
                </li> function () {
                    newsOverlay.classList.remove("active");
                    document.body.style.overflow = ""; 
                    stopNewsTimer();
                });

                newsOverlay.addEventListener("click", function (e) {
                    if (e.target === newsOverlay) {
                        closeNewsBtn.click();
                    }
                });
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>