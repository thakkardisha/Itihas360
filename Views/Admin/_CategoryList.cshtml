@model IEnumerable<Itihas360.Models.Category>

<div class="card shadow-sm p-4 border-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold text-secondary text-uppercase" style="letter-spacing: 1px;">Categories / Sectors</h3>
        <button class="btn btn-primary px-4 shadow-sm"
                onclick="triggerAdd({
                    endpoint: 'Categories',
                    title: 'New Category',                    
                    fields: [
                        { name: 'categoryName', label: 'Name', type: 'text' },
                        { name: 'categorySlug', label: 'Slug', type: 'text' },
                        { name: 'description', label: 'Description', type: 'textarea' },
                        { name: 'displayOrder', label: 'Order', type: 'number' },
                        { name: 'isActive', label: 'Active', type: 'checkbox' } // Must be checkbox
                    ]
                })">
            <i class="fa fa-plus me-2"></i>Add Category
        </button>
    </div>

    <table class="table table-hover align-middle">
        <thead class="bg-light">
            <tr class="text-muted small text-uppercase">
                <th class="ps-3">Order</th>
                <th>Name</th>
                <th>Slug</th>
                <th>Status</th>
                <th class="text-end pe-3">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr id="row-@item.CategoryId">
                    <td class="ps-3 fw-bold text-primary">@item.DisplayOrder</td>
                    <td>@item.CategoryName</td>
                    <td><code class="small">@item.CategorySlug</code></td>
                    <td>
                        @if (item.IsActive == true)
                        {
                            <span class="badge bg-success-soft text-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-danger-soft text-danger">Inactive</span>
                        }
                    </td>
                    <td class="text-end pe-3">
                        <button class="btn btn-outline-secondary btn-sm me-1 border-0"
                                onclick="triggerEdit({
                                    endpoint: 'Categories',
                                    id: @item.CategoryId,
                                    idField: 'categoryId',
                                    title: 'Edit Category',
                                    fields: [
                                        { name: 'categoryName', label: 'Name', type: 'text', value: '@item.CategoryName' },
                                        { name: 'categorySlug', label: 'Slug', type: 'text', value: '@item.CategorySlug' },
                                        { name: 'description', label: 'Description', type: 'textarea', value: '@(item.Description ?? "")' },
                                        { name: 'displayOrder', label: 'Order', type: 'number', value: '@item.DisplayOrder' },
                                        { name: 'isActive', label: 'Active', type: 'checkbox', value: @(item.IsActive.ToString().ToLower()) }
                                    ]
                                })">
                            <i class="fa fa-pencil text-primary"></i>
                        </button>
                        <button class="btn btn-outline-secondary btn-sm border-0"
                                onclick="quickDelete(@item.CategoryId, 'Categories')">
                            <i class="fa fa-trash text-danger"></i>
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>