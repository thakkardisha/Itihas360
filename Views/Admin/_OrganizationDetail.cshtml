@model Itihas360.Models.Organization

<div class="card border-0 shadow-sm">
    <div class="card-body p-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h5 class="fw-bold mb-0">Organization Details</h5>
            @if (Model != null && Model.OrganizationId > 0)
            {
                <div class="d-flex gap-2">
                    <button class="btn btn-primary btn-sm" onclick="editOrg()">
                        <i class="fa fa-edit me-1"></i> Edit Info
                    </button>
                    <button class="btn btn-danger btn-sm" onclick="deleteOrg()">
                        <i class="fa fa-trash me-1"></i> Delete
                    </button>
                </div>
            }
            else
            {
                <button class="btn btn-success btn-sm" onclick="addOrg()">
                    <i class="fa fa-plus me-1"></i> Setup Organization
                </button>
            }
        </div>

        @if (Model != null && Model.OrganizationId > 0)
        {
            <!-- Show real data only when a record truly exists -->
            <div class="row">
                <div class="col-md-3 text-center">
                    <img src="@(string.IsNullOrEmpty(Model.OrganizationPhoto) ? "/img/default-logo.png" : Model.OrganizationPhoto)"
                         class="img-fluid rounded shadow-sm border" alt="Logo" style="max-height:150px;">
                </div>
                <div class="col-md-9">
                    <h3>@Model.OrganizationName</h3>
                    <p class="text-muted"><i class="fa fa-envelope me-2"></i>@Model.Email</p>
                    <p class="text-muted"><i class="fa fa-phone me-2"></i>@(Model.Mobile?.ToString() ?? "N/A")</p>
                    <p class="text-muted">
                        <i class="fa fa-map-marker-alt me-2"></i>
                        @(Model.CompanyAddress ?? "No Address"), @(Model.City ?? "No City")
                    </p>
                    <div class="mt-2 d-flex gap-3">
                        @if (!string.IsNullOrEmpty(Model.Instagram))
                        {
                            <a href="@Model.Instagram" target="_blank" class="text-danger">
                                <i class="fab fa-instagram fa-lg"></i>
                            </a>
                        }
                        @if (!string.IsNullOrEmpty(Model.Facebook))
                        {
                            <a href="@Model.Facebook" target="_blank" class="text-primary">
                                <i class="fab fa-facebook fa-lg"></i>
                            </a>
                        }
                        @if (!string.IsNullOrEmpty(Model.LinkedIn))
                        {
                            <a href="@Model.LinkedIn" target="_blank" class="text-info">
                                <i class="fab fa-linkedin fa-lg"></i>
                            </a>
                        }
                        @if (!string.IsNullOrEmpty(Model.X))
                        {
                            <a href="@Model.X" target="_blank" class="text-dark">
                                <i class="fab fa-x-twitter fa-lg"></i>
                            </a>
                        }
                    </div>
                </div>
            </div>
        }
        else
        {
            <!-- Clean empty state — no fake data -->
            <div class="text-center py-5 text-muted">
                <i class="fa fa-building fa-3x mb-3 opacity-25"></i>
                <p class="mb-1">No organization has been set up yet.</p>
                <p class="small">Click <strong>Setup Organization</strong> to get started.</p>
            </div>
        }
    </div>
</div>

<script>
    function editOrg() {
        window.triggerEdit({
            title: 'Update Organization',
            endpoint: 'Organizations',
            id: @(Model?.OrganizationId ?? 0),
            idField: 'organizationId',
            fields: [
                { name: 'organizationName', label: 'Organization Name', type: 'text', value: '@Model?.OrganizationName' },
                { name: 'organizationPhoto', label: 'Update Logo', type: 'file', value: '@Model?.OrganizationPhoto' },
                { name: 'email', label: 'Email Address', type: 'email', value: '@Model?.Email' },
                { name: 'mobile', label: 'Mobile', type: 'number', value: '@Model?.Mobile' },
                { name: 'alterMobile', label: 'Alternate Mobile', type: 'number', value: '@Model?.AlterMobile' },
                { name: 'companyAddress', label: 'Address', type: 'textarea', value: '@Model?.CompanyAddress' },
                { name: 'city', label: 'City', type: 'text', value: '@Model?.City' },
                { name: 'state', label: 'State', type: 'text', value: '@Model?.State' },
                { name: 'instagram', label: 'Instagram Link', type: 'text', value: '@Model?.Instagram' },
                { name: 'facebook', label: 'Facebook Link', type: 'text', value: '@Model?.Facebook' },
                { name: 'linkedIn', label: 'LinkedIn Link', type: 'text', value: '@Model?.LinkedIn' },
                { name: 'x', label: 'X (Twitter) Link', type: 'text', value: '@Model?.X' }
            ]
        });
    }

    function addOrg() {
        window.triggerAdd({
            title: 'Setup Organization',
            endpoint: 'Organizations',
            idField: 'organizationId',
            fields: [
                { name: 'organizationName', label: 'Organization Name', type: 'text' },
                { name: 'organizationPhoto', label: 'Logo', type: 'file' },
                { name: 'email', label: 'Email Address', type: 'email' },
                { name: 'mobile', label: 'Mobile', type: 'number' },
                { name: 'alterMobile', label: 'Alternate Mobile', type: 'number' },
                { name: 'companyAddress', label: 'Address', type: 'textarea' },
                { name: 'city', label: 'City', type: 'text' },
                { name: 'state', label: 'State', type: 'text' },               
                { name: 'instagram', label: 'Instagram Link', type: 'text' },
                { name: 'facebook', label: 'Facebook Link', type: 'text' },
                { name: 'linkedIn', label: 'LinkedIn Link', type: 'text' },
                { name: 'x', label: 'X (Twitter) Link', type: 'text' }
            ]
        });
    }

    function deleteOrg() {
        quickDelete(@(Model?.OrganizationId ?? 0), 'Organizations');
    }
</script>