@model IEnumerable<Itihas360.Models.NewsFeedCache>

<div class="card shadow-sm p-4 border-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold text-secondary text-uppercase" style="letter-spacing: 1px;">News Feed Cache</h3>
        <span class="badge bg-light text-dark border p-2 small">Total Cached Items: @Model.Count()</span>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="bg-light">
                <tr class="text-muted small text-uppercase">
                    <th class="ps-3" style="width: 45%;">Article Details</th>
                    <th style="width: 15%;">Source & Link</th>                     
                    <th style="width: 15%;">Fetched At</th>                    
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">No data cached in the database system.</td>
                    </tr>
                }
                @foreach (var item in Model)
                {
                    <tr id="row-@item.NewsCacheId">
                        <td class="ps-3">
                            <div class="fw-bold text-dark text-truncate" style="max-width: 400px;" title="@item.Headline">
                                @item.Headline
                            </div>
                            @if (!string.IsNullOrEmpty(item.Summary))
                            {
                                <div class="text-muted small text-truncate" style="max-width: 400px;" title="@item.Summary">
                                    @item.Summary
                                </div>
                            }
                        </td>
                        <td>
                            <span class="text-secondary fw-medium">@(!string.IsNullOrEmpty(item.SourceName) ? item.SourceName : "Unknown")</span>
                            @if (!string.IsNullOrEmpty(item.SourceUrl))
                            {
                                <a href="@item.SourceUrl" target="_blank" class="ms-1 text-primary text-decoration-none" title="Visit Source Link">
                                    <i class="fa-solid fa-arrow-up-right-from-square small"></i>
                                </a>
                            }
                        </td>                        
                        <td class="text-muted small">
                            @(item.FetchedAt?.ToString("g") ?? "N/A")
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>