@using System.Text.Encodings.Web

@model Itihas360.Models.ViewModels.ArticleReadingViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";

    // Set titles and page states
    ViewData["Title"] = Model.Article.Title + " — Itihas 360";
    ViewData["ActivePage"] = "Articles";
}

@section HeadStyles {
    <style>
        :root {
            --parch-1: #f2e8d0;
            --parch-2: #e8d9b5;
            --parch-3: #d9c490;
            --ink: #261605;
            --ink-2: #2d1f08;
            --ink-3: #3d2b0e;
            --gold: #a07820;
            --gold-bright: #c9960a;
            --success-accent: #2e5a1c;
            --error-accent: #8c251e;
        }

        body {
            background-color: var(--parch-1);
            color: var(--ink);
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.15rem;
        }

        /* Document Container & Typography */
        .chronicle-container {
            max-width: 950px;
            margin: 4rem auto;
            padding: 3.5rem;
            background-color: var(--parch-2);
            border: 1px solid var(--parch-3);
            box-shadow: 0 10px 30px rgba(38, 22, 5, 0.05);
            border-radius: 4px;
        }

        .chronicle-title {
            font-family: 'Cinzel', serif;
            color: var(--ink);
            font-weight: 700;
            letter-spacing: 0.05em;
        }

        .chronicle-body {
            content: "";
            display: table;
            clear: both;
            width: 100%;
        }

            /* Image Floating Architecture */
            .chronicle-body .chronicle-img-float {
                display: block !important;
                width: 65% !important;
                max-width: 65% !important;
                margin-bottom: 1.5rem !important;
                border: 1px solid var(--parch-3) !important;
                padding: 0.75rem !important;
                background-color: var(--parch-1) !important;
                box-shadow: 0 6px 20px rgba(0,0,0,0.08) !important;
            }

            .chronicle-body .img-align-right {
                float: right !important;
                margin-left: 2.5rem !important;
                margin-right: 0 !important;
            }

            .chronicle-body .img-align-left {
                float: left !important;
                margin-right: 2.5rem !important;
                margin-left: 0 !important;
            }

        @@media (max-width: 768px) {
            .chronicle-body .chronicle-img-float {
                width: 100% !important;
                max-width: 100% !important;
                float: none !important;
                margin-left: 0 !important;
                margin-right: 0 !important;
                margin-top: 1rem !important;
                margin-bottom: 1.5rem !important;
            }
        }

        .chronicle-img-float img {
            width: 100% !important;
            height: auto !important;
            display: block !important;
        }

        .image-caption-text {
            display: block;
            font-size: 0.88rem;
            color: var(--ink-3);
            font-style: italic;
            margin-top: 0.65rem;
            text-align: center;
            line-height: 1.4;
        }

        /* Custom Theme Controls & Action Buttons */
        .btn-codex {
            background-color: var(--ink);
            color: var(--parch-1) !important;
            border: 1px solid var(--ink-3);
            font-family: 'Cinzel', serif;
            font-size: 0.85rem;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            padding: 0.75rem 2rem;
            border-radius: 0;
            transition: all 0.3s ease;
        }

            .btn-codex:hover {
                background-color: var(--gold);
                border-color: var(--gold-bright);
                color: var(--ink) !important;
            }

        /* Quiz Component Styling */
        .quiz-section {
            border-top: 2px double var(--parch-3);
            margin-top: 4rem;
            padding-top: 3rem;
        }

        .quiz-card {
            background-color: var(--parch-1);
            border: 1px solid var(--parch-3);
            border-radius: 0;
            padding: 2rem;
            margin-bottom: 1.5rem;
        }

        .option-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0.75rem 1rem;
            border: 1px solid transparent;
            margin-bottom: 0.5rem;
            cursor: pointer;
            transition: all 0.2s ease;
        }

            .option-row:hover:not(.disabled) {
                background-color: rgba(160, 120, 32, 0.08);
                border-color: var(--parch-3);
            }

            .option-row.disabled {
                cursor: not-allowed;
            }

        .quiz-custom-radio {
            width: 16px;
            height: 16px;
            border: 1px solid var(--ink-3);
            border-radius: 50%;
            margin-right: 12px;
            flex-shrink: 0;
            position: relative;
            transition: all 0.2s ease;
        }

        .option-row:hover:not(.disabled) .quiz-custom-radio {
            border-color: var(--gold);
        }

        .option-row.correct-selection {
            background-color: rgba(46, 90, 28, 0.12) !important;
            border: 1px solid var(--success-accent) !important;
            color: var(--success-accent);
        }

            .option-row.correct-selection .quiz-custom-radio {
                border-color: var(--success-accent);
                background-color: var(--success-accent);
            }

        .option-row.incorrect-selection {
            background-color: rgba(140, 37, 30, 0.1) !important;
            border: 1px solid var(--error-accent) !important;
            color: var(--error-accent);
        }

            .option-row.incorrect-selection .quiz-custom-radio {
                border-color: var(--error-accent);
                background-color: var(--error-accent);
            }

        .explanation-box {
            background-color: var(--parch-2);
            border-left: 3px solid var(--gold);
            padding: 1rem 1.25rem;
            margin-top: 1rem;
            font-size: 1rem;
        }

        .btn-chronicle-outline {
            font-family: 'Cinzel', serif;
            color: var(--ink);
            background: transparent;
            border: 1px solid var(--ink-3);
            border-radius: 0;
            padding: 0.6rem 2rem;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            font-size: 0.9rem;
            font-weight: 600;
            transition: all 0.25s ease;
        }

            .btn-chronicle-outline:hover {
                color: var(--parch-1);
                background-color: var(--ink);
                border-color: var(--ink);
            }

        .share-icon-link:hover {
            transform: scale(1.15);
        }

        #shareCopyLink:hover {
            color: var(--gold) !important;
        }
    </style>
}

<div class="container">
    <article class="chronicle-container">
        <header>
            <div class="text-center mb-3 text-uppercase tracking-wider small opacity-75">
                <i class="fa-regular fa-calendar me-1"></i> @Model.Article.CreatedAt?.ToString("MMMM dd, yyyy")
            </div>
            <h1 class="chronicle-title text-center mb-4">@Model.Article.Title</h1>
            @if (!string.IsNullOrEmpty(Model.Article.ShortBio))
            {
                <p class="lead text-center px-3 opacity-90" style="font-style: italic;">@Model.Article.ShortBio</p>
            }
            <hr style="border-color: var(--parch-3); opacity: 0.5; margin: 2rem auto; width: 60%;">
        </header>

        <div class="chronicle-body mt-4">
            @if (!string.IsNullOrEmpty(Model.Article.DetailedBio))
            {
                var paragraphs = Model.Article.DetailedBio.Split(new[] { "\r\n", "\r", "\n" }, StringSplitOptions.RemoveEmptyEntries).ToList();
                int totalParagraphs = paragraphs.Count;

                bool hasPrimary = !string.IsNullOrEmpty(Model.Article.ImageUrl);
                bool hasSecondary = !string.IsNullOrEmpty(Model.Article.SecondaryImageUrl);

                int primaryTargetIndex = totalParagraphs > 2 ? (totalParagraphs / 4) : 0;
                int secondaryTargetIndex = totalParagraphs > 2 ? ((totalParagraphs * 3) / 4) : 1;

                for (int i = 0; i < totalParagraphs; i++)
                {
                    @* 1. Primary Image (Floats Right) *@
                    @if (hasPrimary && i == primaryTargetIndex)
                    {
                        <div class="chronicle-img-float img-align-right">
                            <img src="@Url.Content("~" + Model.Article.ImageUrl)" alt="Primary Chronicle Display" />
                            @if (!string.IsNullOrEmpty(Model.Article.ImageCaption))
                            {
                                <span class="image-caption-text">@Model.Article.ImageCaption</span>
                            }
                        </div>
                    }

                    @* 2. Secondary Image (Floats Left) *@
                    @if (hasSecondary && i == secondaryTargetIndex)
                    {
                        <div class="chronicle-img-float img-align-left">
                            <img src="@Url.Content("~" + Model.Article.SecondaryImageUrl)" alt="Secondary Image Display" />
                        </div>
                    }

                    <p style="margin-bottom: 1.5rem; line-height: 1.8; text-align: justify;">
                        @paragraphs[i]
                    </p>
                }
            }
            else
            {
                <p class="text-muted text-center italic">No content available for this chronicle.</p>
            }
        </div>

        <div class="text-center mt-5 pt-4">
            <button class="btn-codex" id="btnToggleQuiz" onclick="toggleQuiz()">
                <i class="fa-solid fa-scroll me-2"></i> Challenge the Mind
            </button>
            <button class="btn-codex" id="btnOpenShare" data-bs-toggle="modal" data-bs-target="#shareModal">
                <i class="fa-solid fa-share-nodes me-2"></i> Share this article
            </button>
        </div>

        <div id="quizArea" class="quiz-section" style="display:none;">
            <h3 class="text-center mb-4 font-display text-uppercase tracking-widest" style="font-family:'Cinzel',serif; color:var(--ink);">Knowledge Check</h3>

            @if (Model.Questions != null && Model.Questions.Any())
            {
                foreach (var (q, index) in Model.Questions.Select((v, i) => (v, i)))
                {
                    <div class="quiz-card structural-card-node" data-question-block="@q.QuestionId" data-is-answered="false">
                        <h5 class="mb-4 fw-bold" style="font-family:'Cinzel', serif;">
                            <span style="color:var(--gold);">@(index + 1).</span> @q.QuestionText
                        </h5>

                        <div class="options-group">
                            @foreach (var opt in q.Mcqoptions.OrderBy(o => o.OptionLabel))
                            {
                                <div class="option-row"
                                     data-option-id="@opt.OptionId"
                                     data-correct-check="@(opt.IsCorrect == true ? "true" : "false")"
                                     onclick="window.handleInlineSelection(this)">

                                    <div class="d-flex align-items-center w-100">
                                        <div class="quiz-custom-radio"></div>
                                        <span>
                                            <strong>@opt.OptionLabel.</strong> @opt.OptionText
                                        </span>
                                    </div>
                                    <div class="status-icon-holder"></div>
                                </div>
                            }
                        </div>

                        @if (!string.IsNullOrWhiteSpace(q.ExplanationText))
                        {
                            <div id="explain_@q.QuestionId" class="explanation-box d-none">
                                <div class="text-uppercase fw-bold text-muted small mb-1" style="letter-spacing: 0.1em; font-size: 0.7rem; color: var(--gold) !important;">Historical Context:</div>
                                <div>@q.ExplanationText</div>
                            </div>
                        }
                    </div>
                }

                @* Added the Reset Button UI panel just like Quiz.cshtml *@
                <div id="resetButtonContainer" class="text-center mt-5">
                    <button type="button" class="btn btn-chronicle-outline" onclick="window.resetHistoricalQuiz()">
                        <i class="fa-solid fa-rotate-left me-2"></i> Reset Quiz
                    </button>
                </div>
            }
            else
            {
                <div class="p-4 text-center bg-light border opacity-75">
                    <i class="fa-regular fa-lightbulb mb-2" style="font-size:1.5rem; color:var(--gold);"></i>
                    <p class="mb-0 small">No quiz available for this article record at present.</p>
                </div>
            }
        </div>
    </article>
    <section>
        <h3 class="text-center mb-4" style="font-family:'Cinzel',serif; color:var(--ink);">Related Articles</h3>

        <div class="row g-4">
            @foreach (var related in Model.RelatedArticles)
            {
                <div class="col-md-4">
                    <article class="h-100" style="border: 1px solid var(--parch-3); background: rgba(255,255,255,0.3);">
                        <div class="article-card-img" style="background: @(string.IsNullOrEmpty(related.ImageUrl) ? "linear-gradient(135deg,var(--ink-2),var(--ink))" : $"url('{related.ImageUrl}') center/cover no-repeat"); min-height:180px; width:100%;"></div>

                        <div class="p-3">
                            <h5 class="h6 mb-2" style="font-family:'Cinzel', serif;">@related.Title</h5>
                            <p class="small text-muted mb-3" style="font-size: 0.85rem;">@(related.ShortBio?.Length > 80 ? related.ShortBio.Substring(0, 77) + "..." : related.ShortBio)</p>
                            <a href="/article/@related.Slug" class="text-decoration-none" style="color:var(--ink); font-weight:bold; font-size: 0.8rem;">READ MORE →</a>
                        </div>
                    </article>
                </div>
            }
        </div>

        <div class="text-center mt-4 mb-4">
            <a href="@Url.Action("CategoryDetails", "Home", new { id = Model.Article.Sector?.CategorySlug })" class="btn btn-chronicle-outline">
                More Articles in @(Model.Article.Sector?.CategoryName ?? "General")
            </a>
        </div>
    </section>
</div>

<div class="modal fade" id="shareModal" tabindex="-1" aria-labelledby="shareModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="background-color: var(--parch-2); border: 1px solid var(--parch-3); border-radius: 0;">
            <div class="modal-header" style="border-bottom: 1px solid var(--parch-3);">
                <h5 class="modal-title" id="shareModalLabel" style="font-family: 'Cinzel', serif; color: var(--ink); font-weight: bold; letter-spacing: 0.05em;">
                    Share This Article
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close" style="filter: sepia(1) saturate(5) hue-rotate(340deg);"></button>
            </div>
            <div class="modal-body p-4 text-center">
                <p class="mb-4 text-muted text-center" style="font-style: italic; font-size : 1.5rem">Share on : </p>

                <div class="d-flex justify-content-center gap-4">
                    <a href="#" id="shareWhatsApp" target="_blank" class="share-icon-link" title="Share via WhatsApp" style="color: #25D366; font-size: 2.5rem; transition: transform 0.2s;">
                        <i class="fa-brands fa-square-whatsapp"></i>
                    </a>

                    <a href="#" id="shareFacebook" target="_blank" class="share-icon-link" title="Share via Facebook" style="color: #1877F2; font-size: 2.5rem; transition: transform 0.2s;">
                        <i class="fa-brands fa-square-facebook"></i>
                    </a>

                    <a href="#" id="shareCopyLink" class="share-icon-link" title="Copy Link" style="color: var(--ink); font-size: 2.5rem; transition: transform 0.2s;">
                        <i class="fa-solid fa-square-link"></i>
                    </a>
                </div>

                <div id="copyAlert" class="mt-3 small text-success d-none" style="font-family: 'Cinzel', serif;">
                    Link safely copied to clipboard!
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function toggleQuiz() {
            const area = document.getElementById('quizArea');
            const btn = document.getElementById('btnToggleQuiz');

            if (area.style.display === 'none' || area.style.display === '') {
                area.style.display = 'block';
                btn.innerHTML = '<i class="fa-solid fa-times me-2"></i> Close Quiz';
                area.scrollIntoView({ behavior: 'smooth', block: 'start' });
            } else {
                area.style.display = 'none';
                btn.innerHTML = '<i class="fa-solid fa-scroll me-2"></i> Challenge the Mind';
            }
        }

        document.addEventListener("DOMContentLoaded", function () {
            // 1. Capture contextual variables securely from the rendered page
            const articleTitle = "@Html.Raw(JavaScriptEncoder.Default.Encode(Model.Article.Title))";
            const currentUrl = window.location.href;

            // 2. Formulate proper intent strings for target engines
            const whatsappText = encodeURIComponent(`Read this amazing article: "${articleTitle}" at \n${currentUrl}`);
            const facebookUrl = encodeURIComponent(currentUrl);

            // 3. Assign generated references to the DOM nodes
            document.getElementById("shareWhatsApp").href = `https://api.whatsapp.com/send?text=${whatsappText}`;
            document.getElementById("shareFacebook").href = `https://facebook.com/sharer/sharer.php?u=${facebookUrl}`;

            // 4. Fallback: Minimalist Copy to Clipboard logic
            document.getElementById("shareCopyLink").addEventListener("click", function (e) {
                e.preventDefault();
                navigator.clipboard.writeText(currentUrl).then(() => {
                    const alertBox = document.getElementById("copyAlert");
                    alertBox.classList.remove("d-none");

                    // Auto hide notice alert after 2.5 seconds
                    setTimeout(() => {
                        alertBox.classList.add("d-none");
                    }, 2500);
                }).catch(err => {
                    console.error('Failed to copy the manuscript link: ', err);
                });
            });
        });

        (function () {
            window.handleInlineSelection = function (selectedElement) {
                const currentCard = selectedElement.closest('.structural-card-node');

                // Stop actions if the question block has already been evaluated
                if (currentCard.getAttribute('data-is-answered') === 'true') {
                    return;
                }

                currentCard.setAttribute('data-is-answered', 'true');

                const totalOptions = currentCard.querySelectorAll('.option-row');
                const isTargetCorrect = selectedElement.getAttribute('data-correct-check') === 'true';
                const questionId = currentCard.getAttribute('data-question-block');

                totalOptions.forEach(opt => {
                    opt.classList.add('disabled');

                    // Instantly illuminate the objective truth choice
                    if (opt.getAttribute('data-correct-check') === 'true') {
                        opt.classList.add('correct-selection');
                        opt.querySelector('.status-icon-holder').innerHTML = '<i class="fa fa-check-circle text-success fs-5"></i>';
                    }
                });

                // If user selected an incorrect element, flag it explicitly
                if (!isTargetCorrect) {
                    selectedElement.classList.add('incorrect-selection');
                    selectedElement.querySelector('.status-icon-holder').innerHTML = '<i class="fa fa-times-circle text-danger fs-5"></i>';
                }

                // Fluidly expand the underlying Historical Context panel
                const explanationBox = document.getElementById('explain_' + questionId);
                if (explanationBox) {
                    explanationBox.classList.remove('d-none');
                }
            };

            // Added window.resetHistoricalQuiz function matching Quiz.cshtml functionality
            window.resetHistoricalQuiz = function () {
                const quizCards = document.querySelectorAll('.structural-card-node');

                quizCards.forEach(card => {
                    card.setAttribute('data-is-answered', 'false');

                    const qId = card.getAttribute('data-question-block');
                    const explanationBox = document.getElementById('explain_' + qId);
                    if (explanationBox) {
                        explanationBox.classList.add('d-none');
                    }

                    const options = card.querySelectorAll('.option-row');
                    options.forEach(opt => {
                        opt.classList.remove('disabled', 'correct-selection', 'incorrect-selection');

                        const iconHolder = opt.querySelector('.status-icon-holder');
                        if (iconHolder) {
                            iconHolder.innerHTML = '';
                        }
                    });
                });

                // Smooth scroll back to the top of the Knowledge Check section smoothly
                window.scrollTo({
                    top: document.getElementById('quizArea').offsetTop - 20,
                    behavior: 'smooth'
                });
            };
        })();
    </script>
}