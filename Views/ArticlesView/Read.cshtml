@model Itihas360.Models.ViewModels.ArticleReadingViewModel
@{
    Layout = null;
    ViewData["Title"] = Model.Article.Title;
}
<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Itihas360</title>
    <link rel="stylesheet" href="~/css/global.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">
</head>
<body>
    <div class="container">
        <article class="chronicle-container">

            <header>
                <div class="chronicle-meta text-center">
                    <span>@Model.Article.CreatedAt?.ToString("MMMM dd, yyyy")</span>
                </div>

                <h1 class="chronicle-title display-4 text-center">@Model.Article.Title</h1>

                @if (!string.IsNullOrEmpty(Model.Article.ShortBio))
                {
                    <p class="chronicle-subtitle">@Model.Article.ShortBio</p>
                }

                <div class="rule-triple mx-auto my-4"></div>
            </header>

            <div class="chronicle-body mt-5">
                @if (!string.IsNullOrEmpty(Model.Article.DetailedBio))
                {
                    var paragraphs = Model.Article.DetailedBio.Split(new[] { "\r\n", "\r", "\n" }, StringSplitOptions.RemoveEmptyEntries);
                    foreach (var p in paragraphs)
                    {
                        <p>@p</p>
                    }
                }
                else
                {
                    <p class="text-muted italic text-center">No content available for this chronicle.</p>
                }
            </div>

            <div class="text-center mt-5 pt-4">
                @* Added btn-unlock here *@
                <button class="btn-unlock" id="btnToggleQuiz" onclick="toggleQuiz()">
                    <i class="fa fa-scroll me-2"></i> Challenge the Mind
                </button>
            </div>

            <div id="quizArea" class="quiz-section" style="display:none;">
                <h3 class="text-center mb-5 font-display" style="color:var(--ink);">Knowledge Check</h3>

                @if (Model.Questions != null && Model.Questions.Any())
                {
                    foreach (var (q, index) in Model.Questions.Select((v, i) => (v, i)))
                    {
                        <div class="quiz-card p-4 mb-4">
                            <h5 class="fw-bold mb-4">@(index + 1). @q.QuestionText</h5>

                            @foreach (var opt in q.Mcqoptions)
                            {
                                <div class="form-check mb-2">
                                    <input class="form-check-input" type="radio" name="q_@q.QuestionId" id="opt_@opt.OptionId">
                                    <label class="form-check-label ms-2" for="opt_@opt.OptionId">
                                        <strong>@opt.OptionLabel.</strong> @opt.OptionText
                                    </label>
                                </div>
                            }

                            <div id="explain_@q.QuestionId" class="mt-3 p-3 small bg-light d-none border-start border-warning">
                                <span class="text-uppercase fw-bold text-muted" style="font-size:0.6rem;">Clarification:</span><br />
                                @q.ExplanationText
                            </div>
                        </div>
                    }

                    <div class="text-center">
                        <button class="btn btn-outline-dark px-5" onclick="revealAnswers()">Evaluate Answers</button>
                    </div>
                }
                else
                {
                    <div class="p-4 bg-light rounded border">
                        <div class="quiz-empty-container">
                            <i class="fa fa-lightbulb-o quiz-info-icon"></i>
                            <p class="mb-0 small">No quiz available for this article yet.</p>
                        </div>
                    </div>
                }
            </div>
        </article>
    </div>

    <script>
        function toggleQuiz() {
            const area = document.getElementById('quizArea');
            const btn = document.getElementById('btnToggleQuiz');

            if (area.style.display === 'none' || area.style.display === '') {
                area.style.display = 'block';
                btn.innerHTML = 'Close Quiz';
                area.scrollIntoView({ behavior: 'smooth' });
            } else {
                area.style.display = 'none';
                btn.innerHTML = '<i class="fa fa-scroll me-2"></i> Challenge the Mind';
            }
        }

        function revealAnswers() {
            const radios = document.querySelectorAll('.form-check-input');
            let answered = false;
            radios.forEach(r => { if (r.checked) answered = true; });

            if (!answered) {
                alert("Take a guess before checking the results!");
                return;
            }

            document.querySelectorAll('[id^="explain_"]').forEach(el => el.classList.remove('d-none'));
        }
    </script>
</body>
</html>