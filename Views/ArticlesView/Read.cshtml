@model Itihas360.Models.ViewModels.ArticleReadingViewModel
@{
    Layout = null;
    ViewData["Title"] = Model.Article.Title;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Itihas360</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/global.css" asp-append-version="true" />

    <style>
        :root {
            --parch-1: #f2e8d0;
            --parch-2: #e8d9b5;
            --parch-3: #d9c490;
            --ink: #261605;
            --ink-2: #2d1f08;
            --ink-3: #3d2b0e;
            --gold: #a07820;
            --gold-bright: #c9960a;
            --success-accent: #2e5a1c;
            --error-accent: #8c251e;
        }

        body {
            background-color: var(--parch-1);
            color: var(--ink);
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.15rem;
        }

        .chronicle-container {
            max-width: 800px;
            margin: 4rem auto;
            padding: 3rem;
            background-color: var(--parch-2);
            border: 1px solid var(--parch-3);
            box-shadow: 0 10px 30px rgba(38, 22, 5, 0.05);
            border-radius: 4px;
        }

        .chronicle-title {
            font-family: 'Cinzel', serif;
            color: var(--ink);
            font-weight: 700;
            letter-spacing: 0.05em;
        }

        /* Museum Codex Custom Controls & Buttons */
        .btn-codex {
            background-color: var(--ink);
            color: var(--parch-1) !important;
            border: 1px solid var(--ink-3);
            font-family: 'Cinzel', serif;
            font-size: 0.85rem;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            padding: 0.75rem 2rem;
            border-radius: 0;
            transition: all 0.3s ease;
        }

            .btn-codex:hover {
                background-color: var(--gold);
                border-color: var(--gold-bright);
                color: var(--ink) !important;
            }

        .btn-codex-outline {
            background-color: transparent;
            color: var(--ink);
            border: 1px solid var(--ink);
            font-family: 'Cinzel', serif;
            font-size: 0.85rem;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            padding: 0.75rem 2rem;
            border-radius: 0;
            transition: all 0.3s ease;
        }

            .btn-codex-outline:hover {
                background-color: var(--ink);
                color: var(--parch-1);
            }

        /* Quiz Layout Refinement */
        .quiz-section {
            border-top: 2px double var(--parch-3);
            margin-top: 4rem;
            padding-top: 3rem;
        }

        .quiz-card {
            background-color: var(--parch-1);
            border: 1px solid var(--parch-3);
            border-radius: 0;
            padding: 2rem;
            margin-bottom: 1.5rem;
            transition: transform 0.2s ease;
        }

        /* Custom Interactive Option Row Elements */
        .option-row {
            display: flex;
            align-items: center;
            padding: 0.75rem 1rem;
            border: 1px solid transparent;
            margin-bottom: 0.5rem;
            cursor: pointer;
            transition: all 0.2s ease;
        }

            .option-row:hover {
                background-color: rgba(160, 120, 32, 0.08);
                border-color: var(--parch-3);
            }

            .option-row input[type="radio"] {
                accent-color: var(--gold);
                width: 18px;
                height: 18px;
                cursor: pointer;
            }

            /* Evaluation UI Feedback States */
            .option-row.correct-selection {
                background-color: rgba(46, 90, 28, 0.12) !important;
                border: 1px solid var(--success-accent) !important;
                color: var(--success-accent);
            }

            .option-row.incorrect-selection {
                background-color: rgba(140, 37, 30, 0.1) !important;
                border: 1px solid var(--error-accent) !important;
                color: var(--error-accent);
            }

        .explanation-box {
            background-color: var(--parch-2);
            border-left: 3px solid var(--gold);
            padding: 1rem 1.25rem;
            margin-top: 1rem;
            font-size: 1rem;
        }
    </style>
</head>
<body>
    <div class="container">
        <article class="chronicle-container">
            <header>
                <div class="text-center mb-3 text-uppercase tracking-wider small opacity-75">
                    <i class="fa-regular fa-calendar me-1"></i> @Model.Article.CreatedAt?.ToString("MMMM dd, yyyy")
                </div>
                <h1 class="chronicle-title text-center mb-4">@Model.Article.Title</h1>
                @if (!string.IsNullOrEmpty(Model.Article.ShortBio))
                {
                    <p class="lead text-center px-3 opacity-90" style="font-style: italic;">@Model.Article.ShortBio</p>
                }
                <hr style="border-color: var(--parch-3); opacity: 0.5; margin: 2rem auto; width: 60%;">
            </header>

            <div class="chronicle-body mt-4">
                @if (!string.IsNullOrEmpty(Model.Article.DetailedBio))
                {
                    var paragraphs = Model.Article.DetailedBio.Split(new[] { "\r\n", "\r", "\n" }, StringSplitOptions.RemoveEmptyEntries).ToList();
                    foreach (var para in paragraphs)
                    {
                        <p style="margin-bottom: 1.5rem; line-height: 1.8; text-align: justify;">@para</p>
                    }
                }
                else
                {
                    <p class="text-muted text-center italic">No content available for this chronicle.</p>
                }
            </div>

            <div class="text-center mt-5 pt-4">
                <button class="btn-codex" id="btnToggleQuiz" onclick="toggleQuiz()">
                    <i class="fa-solid fa-scroll me-2"></i> Challenge the Mind
                </button>
            </div>

            <div id="quizArea" class="quiz-section" style="display:none;">
                <h3 class="text-center mb-4 font-display text-uppercase tracking-widest" style="font-family:'Cinzel',serif; color:var(--ink);">Knowledge Check</h3>

                @if (Model.Questions != null && Model.Questions.Any())
                {
                    foreach (var (q, index) in Model.Questions.Select((v, i) => (v, i)))
                    {
                        <div class="quiz-card" data-question-block="@q.QuestionId">
                            <h5 class="mb-4 fw-bold" style="font-family:'Cinzel', serif;">
                                <span style="color:var(--gold);">@(index + 1).</span> @q.QuestionText
                            </h5>

                            <div class="options-group">
                                @foreach (var opt in q.Mcqoptions)
                                {
                                    <label class="option-row" for="opt_@opt.OptionId">
                                        <div class="d-flex align-items-center w-100">
                                            <input class="form-check-input m-0" type="radio"
                                                   name="q_@q.QuestionId"
                                                   id="opt_@opt.OptionId"
                                                   data-is-correct="@(opt.IsCorrect == true ? "true" : "false")">
                                            <span class="ms-3">
                                                <strong>@opt.OptionLabel.</strong> @opt.OptionText
                                            </span>
                                        </div>
                                    </label>
                                }
                            </div>

                            <div id="explain_@q.QuestionId" class="explanation-box d-none">
                                <div class="text-uppercase fw-bold text-muted small mb-1" style="letter-spacing: 0.1em; font-size: 0.7rem;">Explanation:</div>
                                <div>@q.ExplanationText</div>
                            </div>
                        </div>
                    }

                    <div class="text-center mt-4">
                        <button class="btn-codex-outline w-100 py-3" onclick="revealAnswers()">Evaluate Answers</button>
                    </div>
                }
                else
                {
                    <div class="p-4 text-center bg-light border opacity-75">
                        <i class="fa-regular fa-lightbulb mb-2" style="font-size:1.5rem; color:var(--gold);"></i>
                        <p class="mb-0 small">No quiz choices are available for this chronicle record at present.</p>
                    </div>
                }
            </div>
        </article>
    </div>

    <script>
        function toggleQuiz() {
            const area = document.getElementById('quizArea');
            const btn = document.getElementById('btnToggleQuiz');

            if (area.style.display === 'none' || area.style.display === '') {
                area.style.display = 'block';
                btn.innerHTML = '<i class="fa-solid fa-times me-2"></i> Close Quiz';
                area.scrollIntoView({ behavior: 'smooth', block: 'start' });
            } else {
                area.style.display = 'none';
                btn.innerHTML = '<i class="fa-solid fa-scroll me-2"></i> Challenge the Mind';
            }
        }

        function revealAnswers() {
            // Find all unique question block containers
            const questionBlocks = document.querySelectorAll('[data-question-block]');
            let overallValid = true;

            questionBlocks.forEach(block => {
                const radios = block.querySelectorAll('input[type="radio"]');
                let questionAnswered = false;

                // 1. Check if the user selected an option for this block
                radios.forEach(r => { if (r.checked) questionAnswered = true; });

                if (!questionAnswered) {
                    overallValid = false;
                    return;
                }

                // 2. Clear out any legacy evaluation styles from a previous run
                block.querySelectorAll('.option-row').forEach(row => {
                    row.classList.remove('correct-selection', 'incorrect-selection');
                });

                // 3. Evaluate selected option items
                radios.forEach(radio => {
                    const optionContainer = radio.closest('.option-row');
                    const isCorrect = radio.getAttribute('data-is-correct') === 'true';

                    if (radio.checked) {
                        if (isCorrect) {
                            optionContainer.classList.add('correct-selection');
                        } else {
                            optionContainer.classList.add('incorrect-selection');
                        }
                    } else if (isCorrect) {
                        // Highlight the actual correct answer if the user picked wrong
                        optionContainer.classList.add('correct-selection');
                    }
                });

                // 4. Reveal the item's corresponding clarification explanation box
                const explanationBox = block.querySelector('.explanation-box');
                if (explanationBox) {
                    explanationBox.classList.remove('d-none');
                }
            });

            if (!overallValid) {
                alert("Please answer all questions before checking the results!");
            }
        }
    </script>
</body>
</html>