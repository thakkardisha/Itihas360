@{
    Layout = "_Layout";
}

<div class="about-wrapper">

    <header class="about-hero-dark">
        <div class="container">
            <span class="text-uppercase small d-block mb-2 hero-tag">Our Mission</span>
            <h1 class="about-main-title display-4">Chronicles of Civilization</h1>
            <div class="rule-triple my-3 mx-auto"></div>
        </div>
    </header>

    <section class="container narrative-section">
        <div class="row justify-content-center">
            <div class="col-lg-9 col-md-12">
                <span class="section-marker">Who We Are</span>
                <h2 class="narrative-heading">We make history clear, approachable, and truly meaningful for everyone.</h2>

                <p class="narrative-lead">
                    Welcome to Itihas360. We believe that discovering the past shouldn't feel like decoding a heavy academic textbook. History is a collection of real, vibrant human stories—filled with triumphs, innovations, and fascinating cultural evolution. Our goal is to share these milestones using simple, natural language.
                </p>

                <p class="narrative-copy">
                    Whether you are exploring the timelines of ancient empires, tracking major global events chronologically, or uncovering the unique traditions of distinct world civilizations, we provide a clean, peaceful space designed entirely for reading. We leave out the clutter so you can focus on what matters most: your journey through time.
                </p>
            </div>
        </div>
    </section>

    <section class="value-grid">
        <div class="container">
            <div class="row g-4 justify-content-center">

                <div class="col-lg-4 col-md-6">
                    <div class="value-card">
                        <div class="value-icon"><i class="fa-solid fa-feather-alt"></i></div>
                        <h3 class="value-title">Natural Language</h3>
                        <p class="value-desc">We break down complex scholarly concepts and present them in straightforward descriptions, making history highly enjoyable to read without missing critical factual details.</p>
                    </div>
                </div>

                <div class="col-lg-4 col-md-6">
                    <div class="value-card">
                        <div class="value-icon"><i class="fa-solid fa-timeline"></i></div>
                        <h3 class="value-title">Linear Clarity</h3>
                        <p class="value-desc">Our sequential vertical nodes map historical movements chronologically. You can watch human development unfold cleanly without overlapping layouts or visual strain.</p>
                    </div>
                </div>

                <div class="col-lg-4 col-md-6">
                    <div class="value-card">
                        <div class="value-icon"><i class="fa-solid fa-globe"></i></div>
                        <h3 class="value-title">Complete 360° View</h3>
                        <p class="value-desc">From world civilizations and cross-border trade networks to unique localized art forms and architectural wonders, we trace the full tapestry of world inheritance.</p>
                    </div>
                </div>

            </div>
        </div>
    </section>

    <section class="container about-cta-section">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <h4 class="mb-3">Begin Your Journey Through Time</h4>
                <p class="mx-auto mb-4 cta-text">
                    Dive straight into our clean chronological systems and trace the remarkable milestones that shaped our present world.
                </p>
                <a href="/timeline" class="btn-editorial-gold">Explore the Timeline</a>
            </div>
        </div>
    </section>

</div>