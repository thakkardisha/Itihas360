@model Itihas360.Models.HomeViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Itihas 360 — A complete view of world history, civilisations and cultures." />
    <title>Itihas 360 — A Complete View of History</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/global.css" />
    <style>
        /* Fix for Navbar background color and toggle structure when collapsed on mobile devices */
        #navMenu {
            transition: background-color 0.3s ease;
        }

        @@media (max-width: 991.98px) {
            #navMenu.collapse.show, #navMenu.collapsing {
                background-color: var(--ink) !important; /* Forces solid background when expanded */
                padding: 1.25rem;
                border-radius: 6px;
                border: 1px solid var(--border-lt);
                margin-top: 0.75rem;
                display: block !important;
            }
        }

        /* Explicit layer alignment fix for custom Notification Overlay panel */
        #notifPanel {
            position: fixed;
            top: 75px;
            right: -400px;
            width: 350px;
            max-width: 90vw;
            height: auto;
            max-height: 80vh;
            background-color: var(--ink-2);
            border: 1px solid var(--border-lt);
            box-shadow: 0 8px 30px rgba(0, 0, 0, 0.5);
            z-index: 1060;
            transition: right 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            display: flex;
            flex-direction: column;
        }

            #notifPanel.active {
                right: 20px;
            }

        /* Identical structural heights mapping for Secondary Cards */
        .hero-secondary-card {
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            height: 100%;
            min-height: 120px;
        }
    </style>
</head>
<body>

    <div id="searchOverlay" role="dialog" aria-modal="true" aria-label="Search">
        <div class="search-wrap">
            <div class="search-inner">
                <i class="fa fa-search" style="color:var(--gold);font-size:1.3rem;flex-shrink:0;"></i>
                <form id="searchForm" action="/articles" method="get" class="w-100 m-0 d-flex align-items-center">
                    <input type="text" id="searchInput" name="search" placeholder="Search the articles and hit enter…" autocomplete="off" class="bg-transparent border-0 w-100 text-white ms-2" style="outline: none;" />
                </form>
                <button class="search-close-btn" id="searchClose"><i class="fa fa-times"></i></button>
            </div>
            <div class="search-tags mt-3">
                <span class="search-tag-label me-1">Categories ·</span>
                @foreach (var cat in Model.Categories.Take(6))
                {
                    <span class="search-tag" style="cursor:pointer;" onclick="redirectToCategory('@cat.Category.CategorySlug')">
                        @cat.Category.CategoryName
                    </span>
                }
            </div>
        </div>
    </div>

    <div id="notifPanel" role="dialog" aria-label="Notifications">
        <div class="notif-panel-header d-flex justify-content-between align-items-center p-3" style="border-bottom: 1px solid var(--border-lt);">
            <span class="notif-panel-title text-white">
                <i class="fa fa-scroll me-2" style="font-size:.7rem; color: var(--gold);"></i>Recent Dispatches
            </span>
            <button class="notif-panel-close bg-transparent border-0 text-white opacity-75" id="notifClose"><i class="fa fa-times"></i></button>
        </div>

        <div class="notif-panel-body p-2" style="overflow-y: auto;">
            @if (Model.LatestArticles == null || !Model.LatestArticles.Any())
            {
                <div class="notif-empty text-center py-4 opacity-50 text-white">No articles published yet.</div>
            }
            else
            {
                foreach (var article in Model.LatestArticles.Take(5))
                {
                    <div class="notif-item p-2 mb-1 rounded text-white" onclick="window.location.href='/article/@article.Slug'" style="cursor:pointer;">
                        <div class="d-flex align-items-start gap-2">
                            <div class="notif-item-icon mt-1" style="color: var(--gold);"><i class="fa fa-feather-alt"></i></div>
                            <div class="notif-item-content">
                                <div class="notif-item-title small" style="font-weight: 600;">@article.Title</div>
                                <div class="notif-item-time opacity-50" style="font-size: 0.7rem;">
                                    <i class="fa fa-calendar-alt me-1"></i>@(article.CreatedAt?.ToString("dd MMM yyyy") ?? "Recent")
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>

        <div class="notif-panel-footer p-3 text-center" style="border-top: 1px solid var(--border-lt);">
            <a href="/articles" class="small text-decoration-none" style="color: var(--gold);">View all articles &rarr;</a>
        </div>
    </div>

    <nav id="mainNav" class="navbar navbar-expand-lg">
        <div class="container">
            <a class="navbar-brand nav-brand" href="/">
                <div class="nav-brand-icon"><i class="fa-solid fa-scroll"></i></div>
                <div>
                    Itihas 360
                    <span class="nav-brand-sub">A Complete View of History</span>
                </div>
            </a>

            <button class="navbar-toggler border-0" type="button"
                    data-bs-toggle="collapse" data-bs-target="#navMenu"
                    aria-controls="navMenu" aria-expanded="false" aria-label="Toggle navigation"
                    style="color:var(--gold);">
                <i class="fa fa-bars"></i>
            </button>

            <div class="collapse navbar-collapse" id="navMenu">
                <ul class="navbar-nav mx-auto gap-1">
                    <li class="nav-item"><a class="nav-link active" href="/">Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="/articles">Articles</a></li>
                    <li class="nav-item"><a class="nav-link" href="/timeline">Timeline</a></li>
                    <li class="nav-item"><a class="nav-link" href="/personalities">Personalities</a></li>
                    <li class="nav-item"><a class="nav-link" href="/categories">Categories</a></li>
                    <li class="nav-item"><a class="nav-link" href="/quiz">Quiz</a></li>
                    <li class="nav-item"><a class="nav-link" href="/about">About</a></li>
                </ul>
                <div class="d-flex align-items-center gap-2 mt-2 mt-lg-0">
                    <button class="nav-notif-btn" id="notifToggle" title="Recent Dispatches" aria-label="Notifications">
                        <i class="fa fa-bell" style="font-size:.85rem;"></i>
                        <span class="notif-dot visible" id="notifDot"></span>
                    </button>
                    <button class="nav-search-btn" id="searchOpenTrigger">
                        <i class="fa fa-search"></i> Search
                    </button>
                </div>
            </div>
        </div>
    </nav>

    <section id="hero">
        <div class="container position-relative py-5">
            <div class="row align-items-center g-5">
                <div class="col-lg-6">
                    <div class="hero-masthead animate-up">
                        <span class="hero-masthead-date" id="heroDate">LOADING...</span>
                    </div>

                    <h1 class="hero-title animate-up d1">
                        History in <em>360&deg;</em><br />Perspective
                    </h1>

                    <p class="hero-subtitle animate-up d2">
                        From ancient civilisations to the modern era &mdash; every empire,
                        every revolution, every untold story, brought to life with
                        scholarly depth and global perspective.
                    </p>

                    <div class="d-flex flex-wrap gap-3 animate-up d3">
                        <a href="/articles" class="btn-codex crimson-btn text-decoration-none">
                            <i class="fa fa-feather-alt"></i> Read the Articles
                        </a>
                        <a href="/timeline" class="btn-codex ghost text-decoration-none">
                            <i class="fa fa-stream"></i> View Timeline
                        </a>
                    </div>

                    <div class="hero-stats animate-up d4">
                        <div>
                            <div class="hero-stat-num">@Model.TotalArticles</div>
                            <div class="hero-stat-label">Articles</div>
                        </div>
                        <div>
                            <div class="hero-stat-num">@Model.TotalCategories</div>
                            <div class="hero-stat-label">Categories</div>
                        </div>
                        <div>
                            <div class="hero-stat-num">@Model.UnreadNotifCount</div>
                            <div class="hero-stat-label">This Week</div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-5 offset-lg-1 animate-in d3">
                    @if (Model.FeaturedArticle != null)
                    {
                        <a href="/article/@Model.FeaturedArticle.Slug" class="codex-card mb-3 d-block text-decoration-none" id="heroFeaturedCard">
                            <div class="codex-card-thumb" style="background-image: url('@(string.IsNullOrEmpty(Model.FeaturedArticle.ImageUrl) ? "/uploads/articles/default.jpg" : Model.FeaturedArticle.ImageUrl)'); background-size: cover; background-position: center; min-height: 200px;">
                                @if (string.IsNullOrEmpty(Model.FeaturedArticle.ImageUrl))
                                {
                                    <i class="fa fa-landmark" style="font-size:3rem;color:rgba(160,120,32,.3);position:relative;z-index:1;"></i>
                                }
                            </div>
                            <div class="codex-card-body">
                                <div class="codex-card-eyebrow">
                                    Cover Story
                                    @if (Model.FeaturedArticle.Sector != null)
                                    {
                                        <span>&middot; @Model.FeaturedArticle.Sector.CategoryName</span>
                                    }
                                </div>
                                <h3 class="codex-card-title">@Model.FeaturedArticle.Title</h3>
                                <div class="codex-card-meta">
                                    @if (Model.FeaturedArticle.CreatedAt.HasValue)
                                    {
                                        <span>
                                            <i class="fa fa-calendar me-1"></i>
                                            @Model.FeaturedArticle.CreatedAt.Value.ToString("dd MMM yyyy")
                                        </span>
                                    }
                                </div>
                            </div>
                        </a>
                    }

                    @if (Model.SecondaryArticles != null && Model.SecondaryArticles.Any())
                    {
                        <div class="row g-2">
                            @foreach (var article in Model.SecondaryArticles)
                            {
                                <div class="col-6">
                                    <a href="/article/@article.Slug" class="codex-card p-3 d-block hero-secondary-card text-decoration-none">
                                        <div>
                                            @if (article.Sector != null)
                                            {
                                                <div class="codex-card-eyebrow" style="font-size:.52rem;">
                                                    @article.Sector.CategoryName
                                                </div>
                                            }
                                            <div class="codex-card-title" style="font-size:.85rem;margin-top:.3rem;">
                                                @article.Title
                                            </div>
                                        </div>
                                        @if (!string.IsNullOrEmpty(article.ImageUrl))
                                        {
                                            <div class="mt-2" style="height: 50px; background: url('@article.ImageUrl') center/cover no-repeat; border-radius: 2px; border: 1px solid var(--border-lt);"></div>
                                        }
                                    </a>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </section>

    @if (Model.LatestArticles != null && Model.LatestArticles.Any())
    {
        <div style="background:var(--parch-2);border-top:1px solid var(--border-lt);border-bottom:1px solid var(--border-lt);padding:.48rem 0;overflow:hidden;">
            <div class="container">
                <div class="d-flex align-items-center gap-3">
                    <span style="font-family:var(--font-display);font-size:.56rem;letter-spacing:.2em;text-transform:uppercase;background:var(--ink);color:var(--gold);padding:.28rem .85rem;white-space:nowrap;border:1px solid var(--ink-3);flex-shrink:0;">
                        Latest Dispatches
                    </span>
                    <div class="ticker-track" style="font-family:var(--font-display);font-size:.65rem;letter-spacing:.1em;text-transform:uppercase;color:var(--ink-3);white-space:nowrap;">
                        @foreach (var a in Model.LatestArticles.Concat(Model.LatestArticles))
                        {
                            <span>@a.Title</span>
                            <span style="margin:0 1.5em;color:var(--border);">&middot;</span>
                        }
                    </div>
                </div>
            </div>
        </div>
    }

    <section id="latest-articles" class="section bg-parch">
        <div class="container">
            <div class="chapter-header reveal">
                <span class="eyebrow">Fresh from the Archives</span>
                <h2 class="section-title">Latest Articles</h2>
                <div class="rule-triple"></div>
            </div>

            <div class="d-flex flex-wrap justify-content-center gap-2 mb-4 reveal">
                <button class="btn-codex active" style="font-size:.62rem;padding:.35rem 1.1rem;" onclick="window.location.href='/articles'">All Articles</button>
                @foreach (var cat in Model.Categories)
                {
                    <button class="btn-codex parch" style="font-size:.62rem;padding:.35rem 1.1rem;" onclick="redirectToCategory('@cat.Category.CategorySlug')">@cat.Category.CategoryName</button>
                }
            </div>

            <div class="row g-4" id="articleGrid">
                @if (Model.LatestArticles == null || !Model.LatestArticles.Any())
                {
                    <div class="col-12 text-center py-5">No articles published yet.</div>
                }
                else
                {
                    int idx = 0;
                    foreach (var article in Model.LatestArticles.Take(6))
                    {
                        idx++;
                        <div class="col-md-6 col-lg-4 reveal d@((idx % 3) + 1) article-search-item">
                            <article class="article-card h-100" onclick="window.location.href='/article/@article.Slug'" style="cursor:pointer;">
                                <div class="article-card-img" style="background: @(string.IsNullOrEmpty(article.ImageUrl) ? "linear-gradient(135deg,var(--ink-2),var(--ink))" : $"url('{article.ImageUrl}') center/cover no-repeat"); min-height: 180px;">
                                    @if (string.IsNullOrEmpty(article.ImageUrl))
                                    {
                                        <i class="fa fa-landmark" style="font-size:2rem;color:rgba(160,120,32,.22);"></i>
                                    }
                                    @if (article.Sector != null)
                                    {
                                        <span class="era-badge">@article.Sector.CategoryName</span>
                                    }
                                </div>
                                <div class="article-card-body">
                                    <h3 class="article-card-title">@article.Title</h3>
                                    <p class="article-card-excerpt">@article.ShortBio</p>
                                </div>
                            </article>
                        </div>
                    }
                }
            </div>
        </div>
    </section>

    <footer id="footer" class="py-5">
        <div class="container">
            <div class="row g-5">
                <div class="col-lg-5 col-md-12">
                    <div class="footer-brand mb-3">
                        <img src="@Model.Organization.OrganizationPhoto" alt="Logo" style="height:30px;" class="me-2" />
                        <span class="h5 text-uppercase tracking-wider">@Model.Organization.OrganizationName</span>
                    </div>
                    <p class="footer-bio small opacity-75 mb-3">
                        @Model.Organization.CompanyAddress, @Model.Organization.City, @Model.Organization.State
                    </p>
                </div>
            </div>
            <hr class="my-4 opacity-10">
            <div class="footer-bottom">
                <span class="small opacity-50">&copy; @DateTime.Now.Year Itihas 360 &nbsp;&middot;&nbsp; All rights reserved</span>
            </div>
        </div>
    </footer>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bundle.min.js"></script>
    <script src="~/js/home.js"></script>

    <script>
        $(document).ready(function () {
            // Panel trigger setup
            $('#notifToggle').on('click', function (e) {
                e.preventDefault();
                e.stopPropagation();
                $('#notifPanel').toggleClass('active');
            });

            $('#notifClose').on('click', function (e) {
                e.preventDefault();
                $('#notifPanel').removeClass('active');
            });

            $(document).on('click', function (e) {
                if (!$(e.target).closest('#notifPanel, #notifToggle').length) {
                    $('#notifPanel').removeClass('active');
                }
            });

            $('#searchOpenTrigger').on('click', function () {
                $('#searchOverlay').addClass('active');
                $('#searchInput').focus();
            });

            $('#searchClose').on('click', function () {
                $('#searchOverlay').removeClass('active');
            });
        });

        function redirectToCategory(slug) {
            window.location.href = '/Articles?category=' + encodeURIComponent(slug);
        }
    </script>
</body>
</html>