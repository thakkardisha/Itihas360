@model Itihas360.Models.HomeViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Itihas 360 — A complete view of world history, civilisations and cultures." />
    <title>Itihas 360 — A Complete View of History</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/global.css" />
</head>
<body>

    <!-- ══ SEARCH OVERLAY ══════════════════════════════════════ -->
    <div id="searchOverlay" role="dialog" aria-modal="true" aria-label="Search">
        <div class="search-wrap">
            <div class="search-inner">
                <i class="fa fa-search" style="color:var(--gold);font-size:1.3rem;flex-shrink:0;"></i>
                <input type="text" id="searchInput" placeholder="Search the chronicles…" autocomplete="off" />
                <button class="search-close-btn" id="searchClose"><i class="fa fa-times"></i></button>
            </div>
            <div class="search-tags mt-3">
                <span class="search-tag-label me-1">Categories ·</span>
                @foreach (var cat in Model.Categories.Take(6))
                {
                    <span class="search-tag" data-slug="@cat.Category.CategorySlug">
                        @cat.Category.CategoryName
                    </span>
                }
            </div>
        </div>
    </div>


    <!-- ══ NOTIFICATION PANEL ══════════════════════════════════ -->
    <div id="notifPanel" role="dialog" aria-label="Notifications">
        <div class="notif-panel-header">
            <span class="notif-panel-title">
                <i class="fa fa-scroll me-2" style="font-size:.7rem;"></i>Chronicle Updates
            </span>
            <button class="notif-panel-close" id="notifClose"><i class="fa fa-times"></i></button>
        </div>

        <div class="notif-panel-body">
            @if (Model.RecentNotifications == null || !Model.RecentNotifications.Any())
            {
                <div class="notif-empty">No new updates in the last 7 days.</div>
            }
            else
            {
                foreach (var article in Model.RecentNotifications)
                {
                    bool isToday = article.CreatedAt?.Date == DateTime.Today;
                    int daysAgo = (DateTime.Today - (article.CreatedAt?.Date ?? DateTime.Today)).Days;
                    string timeLabel = isToday ? "Today"
                    : daysAgo == 1 ? "Yesterday"
                    : daysAgo + " days ago";

                    <div class="notif-item @(isToday ? "unread" : "")"
                         onclick="window.location.href='/article/@article.Slug'"
                         style="cursor:pointer;">
                        <div class="notif-item-icon">
                            <i class="fa fa-feather-alt"></i>
                        </div>
                        <div class="notif-item-content">
                            <div class="notif-item-type">
                                @if (isToday)
                                {
                                    <span class="unread-dot"></span>
                                }
                                @(isToday ? "New Article" : "Article")
                                @if (article.Sector != null)
                                {
                                    <span style="opacity:.5;">&middot; @article.Sector.CategoryName</span>
                                }
                            </div>
                            <div class="notif-item-title">@article.Title</div>
                            <div class="notif-item-time">@timeLabel</div>
                        </div>
                    </div>
                }
            }
        </div>

        <div class="notif-panel-footer">
            <a href="/articles">View all articles &rarr;</a>
        </div>
    </div>


    <!-- ══ NAVBAR ═══════════════════════════════════════════════ -->
    <nav id="mainNav" class="navbar navbar-expand-lg">
        <div class="container">

            <a class="navbar-brand nav-brand" href="/">
                <div class="nav-brand-icon"><i class="fa-solid fa-scroll"></i></div>
                <div>
                    Itihas 360
                    <span class="nav-brand-sub">A Complete View of History</span>
                </div>
            </a>

            <button class="navbar-toggler border-0" type="button"
                    data-bs-toggle="collapse" data-bs-target="#navMenu"
                    style="color:var(--gold);">
                <i class="fa fa-bars"></i>
            </button>

            <div class="collapse navbar-collapse" id="navMenu">
                <ul class="navbar-nav mx-auto gap-1">
                    <li class="nav-item"><a class="nav-link active" href="/">Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="/articles">Articles</a></li>
                    <li class="nav-item"><a class="nav-link" href="/timeline">Timeline</a></li>
                    <li class="nav-item"><a class="nav-link" href="/personalities">Personalities</a></li>
                    <li class="nav-item"><a class="nav-link" href="/categories">Categories</a></li>
                    <li class="nav-item"><a class="nav-link" href="/quiz">Quiz</a></li>
                    <li class="nav-item"><a class="nav-link" href="/about">About</a></li>
                </ul>
                <div class="d-flex align-items-center gap-2 mt-2 mt-lg-0">

                    <button class="nav-notif-btn" id="notifToggle"
                            title="Chronicle Updates" aria-label="Notifications">
                        <i class="fa fa-bell" style="font-size:.85rem;"></i>
                        <span class="notif-dot @(Model.HasTodayNotifications ? "visible" : "")"
                              id="notifDot"></span>
                    </button>

                    <button class="nav-search-btn" id="searchOpenTrigger">
                        <i class="fa fa-search"></i> Search
                    </button>

                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <a href="/Identity/Account/Manage"
                           class="btn-codex ghost" style="font-size:.62rem;padding:.38rem 1rem;">
                            My Account
                        </a>
                    }
                    else
                    {
                        <a href="/Identity/Account/Login"
                           class="btn-codex ghost" style="font-size:.62rem;padding:.38rem 1rem;">
                            Sign In
                        </a>
                    }
                </div>
            </div>
        </div>
    </nav>


    <!-- ══ HERO ═════════════════════════════════════════════════ -->
    <section id="hero">
        <div class="container position-relative py-5">
            <div class="row align-items-center g-5">

                <div class="col-lg-6">
                    <div class="hero-masthead animate-up">
                        <span class="hero-masthead-date" id="heroDate">LOADING...</span>
                        <span style="color:rgba(160,120,32,.35);font-size:1rem;">&#10022;</span>
                        <span class="hero-masthead-vol">Vol. I &nbsp;&middot;&nbsp; Est. 2024</span>
                    </div>

                    <h1 class="hero-title animate-up d1">
                        History in <em>360&deg;</em><br />Perspective
                    </h1>

                    <p class="hero-subtitle animate-up d2">
                        From ancient civilisations to the modern era &mdash; every empire,
                        every revolution, every untold story, brought to life with
                        scholarly depth and global perspective.
                    </p>

                    <div class="d-flex flex-wrap gap-3 animate-up d3">
                        <a href="/articles" class="btn-codex crimson-btn">
                            <i class="fa fa-feather-alt"></i> Read the Chronicles
                        </a>
                        <a href="/timeline" class="btn-codex ghost">
                            <i class="fa fa-stream"></i> View Timeline
                        </a>
                    </div>

                    <div class="hero-stats animate-up d4">
                        <div>
                            <div class="hero-stat-num">@Model.TotalArticles</div>
                            <div class="hero-stat-label">Articles</div>
                        </div>
                        <div>
                            <div class="hero-stat-num">@Model.TotalCategories</div>
                            <div class="hero-stat-label">Categories</div>
                        </div>
                        <div>
                            <div class="hero-stat-num">@Model.UnreadNotifCount</div>
                            <div class="hero-stat-label">This Week</div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-5 offset-lg-1 animate-in d3">
                    @if (Model.FeaturedArticle != null)
                    {
                        <a href="/article/@Model.FeaturedArticle.Slug"
                           class="codex-card mb-3 d-block" id="heroFeaturedCard">
                            <div class="codex-card-thumb">
                                <i class="fa fa-landmark"
                                   style="font-size:3rem;color:rgba(160,120,32,.3);position:relative;z-index:1;"></i>
                            </div>
                            <div class="codex-card-body">
                                <div class="codex-card-eyebrow">
                                    Cover Story
                                    @if (Model.FeaturedArticle.Sector != null)
                                    {
                                        <span>&middot; @Model.FeaturedArticle.Sector.CategoryName</span>
                                    }
                                </div>
                                <h3 class="codex-card-title">@Model.FeaturedArticle.Title</h3>
                                <div class="codex-card-meta">
                                    @if (Model.FeaturedArticle.CreatedAt.HasValue)
                                    {
                                        <span>
                                            <i class="fa fa-calendar me-1"></i>
                                            @Model.FeaturedArticle.CreatedAt.Value.ToString("dd MMM yyyy")
                                        </span>
                                    }
                                </div>
                            </div>
                        </a>
                    }

                    @if (Model.SecondaryArticles != null && Model.SecondaryArticles.Any())
                    {
                        <div class="row g-2">
                            @foreach (var article in Model.SecondaryArticles)
                            {
                                <div class="col-6">
                                    <a href="/article/@article.Slug" class="codex-card p-3 d-block">
                                        @if (article.Sector != null)
                                        {
                                            <div class="codex-card-eyebrow" style="font-size:.52rem;">
                                                @article.Sector.CategoryName
                                            </div>
                                        }
                                        <div class="codex-card-title" style="font-size:.85rem;margin-top:.3rem;">
                                            @article.Title
                                        </div>
                                    </a>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </section>

    <!-- Ticker -->
    @if (Model.LatestArticles != null && Model.LatestArticles.Any())
    {
        <div style="background:var(--parch-2);border-top:1px solid var(--border-lt);border-bottom:1px solid var(--border-lt);padding:.48rem 0;overflow:hidden;">
            <div class="container">
                <div class="d-flex align-items-center gap-3">
                    <span style="font-family:var(--font-display);font-size:.56rem;letter-spacing:.2em;text-transform:uppercase;background:var(--ink);color:var(--gold);padding:.28rem .85rem;white-space:nowrap;border:1px solid var(--ink-3);flex-shrink:0;">
                        Latest Dispatches
                    </span>
                    <div class="ticker-track" style="font-family:var(--font-display);font-size:.65rem;letter-spacing:.1em;text-transform:uppercase;color:var(--ink-3);white-space:nowrap;">
                        @foreach (var a in Model.LatestArticles.Concat(Model.LatestArticles))
                        {
                            <span>@a.Title</span>
                            <span style="margin:0 1.5em;color:var(--border);">&middot;</span>
                        }
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- ══ LATEST ARTICLES ══════════════════════════════════════ -->
    <section id="latest-articles" class="section bg-parch">
        <div class="container">
            <div class="chapter-header reveal">
                <span class="eyebrow">Fresh from the Archives</span>
                <h2 class="section-title">Latest Chronicles</h2>
                <div class="rule-triple"></div>
            </div>

            <div class="d-flex flex-wrap justify-content-center gap-2 mb-4 reveal">
                <button class="btn-codex active" style="font-size:.62rem;padding:.35rem 1.1rem;" data-filter="all">All</button>
                @foreach (var cat in Model.Categories)
                {
                    <button class="btn-codex parch" style="font-size:.62rem;padding:.35rem 1.1rem;" data-filter="@cat.Category.CategorySlug">@cat.Category.CategoryName</button>
                }
            </div>

            <div class="row g-4" id="articleGrid">
                @if (Model.LatestArticles == null || !Model.LatestArticles.Any())
                {
                    <div class="col-12 text-center py-5">No articles published yet.</div>
                }
                else
                {
                    int idx = 0;
                    foreach (var article in Model.LatestArticles)
                    {
                        idx++;
                        <div class="col-md-6 col-lg-4 reveal d@((idx % 3) + 1)" data-category="@(article.Sector?.CategorySlug ?? "")">
                            <article class="article-card h-100" onclick="window.location.href='/article/@article.Slug'">
                                <div class="article-card-img" style="background:linear-gradient(135deg,var(--ink-2),var(--ink));">
                                    <i class="fa fa-landmark" style="font-size:2rem;color:rgba(160,120,32,.22);"></i>
                                    @if (article.Sector != null)
                                    {
                                        <span class="era-badge">@article.Sector.CategoryName</span>
                                    }
                                </div>
                                <div class="article-card-body">
                                    <h3 class="article-card-title">@article.Title</h3>
                                    <p class="article-card-excerpt">@article.ShortBio</p>
                                </div>
                            </article>
                        </div>
                    }
                }
            </div>
        </div>
    </section>

    <!-- ══ FOOTER ════════════════════════════════════════════════ -->
    <footer id="footer" class="py-5">
        <div class="container">
            <div class="row g-5">
                <div class="col-lg-5 col-md-12">
                    <div class="footer-brand mb-3">
                        <img src="@Model.Organization.OrganizationPhoto" alt="Logo" style="height:30px;" class="me-2" />
                        <span class="h5 text-uppercase tracking-wider">@Model.Organization.OrganizationName</span>
                    </div>
                    <p class="footer-bio small opacity-75 mb-3">
                        @Model.Organization.CompanyAddress, @Model.Organization.City, @Model.Organization.State
                    </p>
                    <div class="footer-contact small mb-4">
                        <div class="mb-1"><i class="fa fa-envelope me-2 opacity-50"></i> @Model.Organization.Email</div>
                        <div><i class="fa fa-phone me-2 opacity-50"></i> +91 @Model.Organization.Mobile</div>
                    </div>
                    <div class="footer-socials">
                        <a href="@Model.Organization.X" class="me-3 opacity-50"><i class="fab fa-x-twitter"></i></a>
                        <a href="@Model.Organization.Instagram" class="me-3 opacity-50"><i class="fab fa-instagram"></i></a>
                        <a href="@Model.Organization.LinkedIn" class="me-3 opacity-50"><i class="fab fa-linkedin-in"></i></a>
                        <a href="@Model.Organization.Facebook" class="me-3 opacity-50"><i class="fab fa-facebook"></i></a>
                    </div>
                </div>

                <div class="col-lg-3 col-md-6">
                    <h6 class="footer-heading text-uppercase mb-3">Navigation</h6>
                    <ul class="list-unstyled footer-links">
                        <li><a href="/">Home</a></li>
                        <li><a href="/articles">Chronicles</a></li>
                        <li><a href="/timeline">Timeline</a></li>
                        <li><a href="/personalities">Great Figures</a></li>
                    </ul>
                </div>

                <div class="col-lg-4 col-md-6">
                    <h6 class="footer-heading text-uppercase mb-2">Stay in the Loop</h6>
                    <p class="small opacity-75 mb-3" style="font-size:1.1rem;">
                        Join the inner circle for weekly dispatches from the archives.
                    </p>
                    <form action="/Newsletter/Subscribe" method="post" class="mb-4">
                        <div class="footer-newsletter">
                            <input type="email" name="email" placeholder="Email address" required />
                            <button type="submit"><i class="fa fa-paper-plane"></i></button>
                        </div>
                    </form>
                    <h6 class="footer-heading text-uppercase mb-3">Resources</h6>
                    <ul class="list-unstyled footer-links">
                        <li><a href="/quiz">History Quiz</a></li>
                        <li><a href="/about">Our Mission</a></li>
                    </ul>
                </div>
            </div>

            <hr class="my-4 opacity-10">
            <div class="footer-bottom d-flex justify-content-between align-items-center">
                <span class="small opacity-50">&copy; @DateTime.Now.Year Itihas 360 &nbsp;&middot;&nbsp; All rights reserved</span>
            </div>
        </div>
    </footer>

    <button id="scrollTop" aria-label="Scroll to top"><i class="fa fa-chevron-up"></i></button>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/home.js"></script>
</body>
</html>