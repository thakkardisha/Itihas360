@model Itihas360.Models.HomeViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Itihas 360 — A Complete View of History";
    ViewData["Description"] = "Itihas 360 — A complete view of world history, civilisations and cultures.";
    ViewData["ActivePage"] = "Home";

    // Feed the layout's shared partials
    ViewBag.Organization = Model.Organization;
    ViewBag.Categories = Model.Categories;
    ViewBag.LatestArticles = Model.LatestArticles;
}

@section HeadStyles {
    <style>
        /* Secondary card height fix — Home page only */
        .hero-secondary-card {
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            height: 100%;
            min-height: 120px;
        }
    </style>
}

<!-- ══ HERO ═════════════════════════════════════════════════ -->
<section id="hero">
    <div class="container position-relative py-5">
        <div class="row align-items-center g-5">

            <div class="col-lg-6">
                <div class="hero-masthead animate-up">
                    <span class="hero-masthead-date" id="heroDate">LOADING...</span>
                </div>

                <h1 class="hero-title animate-up d1">
                    History in <em>360&deg;</em><br />Perspective
                </h1>

                <p class="hero-subtitle animate-up d2">
                    From ancient civilisations to the modern era &mdash; every empire,
                    every revolution, every untold story, brought to life with
                    scholarly depth and global perspective.
                </p>

                <div class="d-flex flex-wrap gap-3 animate-up d3">
                    <a href="/articles" class="btn-codex crimson-btn text-decoration-none">
                        <i class="fa fa-feather-alt"></i> Read the Articles
                    </a>
                    <a href="/timeline" class="btn-codex ghost text-decoration-none">
                        <i class="fa fa-stream"></i> View Timeline
                    </a>
                </div>

                <div class="hero-stats animate-up d4">
                    <div>
                        <div class="hero-stat-num">@Model.TotalArticles</div>
                        <div class="hero-stat-label">Articles</div>
                    </div>
                    <div>
                        <div class="hero-stat-num">@Model.TotalCategories</div>
                        <div class="hero-stat-label">Categories</div>
                    </div>
                    <div>
                        <div class="hero-stat-num">@Model.UnreadNotifCount</div>
                        <div class="hero-stat-label">This Week</div>
                    </div>
                </div>
            </div>

            <div class="col-lg-5 offset-lg-1 animate-in d3">
                @if (Model.FeaturedArticle != null)
                {
                    <a href="/article/@Model.FeaturedArticle.Slug"
                       class="codex-card mb-3 d-block text-decoration-none" id="heroFeaturedCard">
                        <div class="codex-card-thumb"
                             style="background-image: url('@(string.IsNullOrEmpty(Model.FeaturedArticle.ImageUrl) ? "/uploads/articles/default.jpg" : Model.FeaturedArticle.ImageUrl)');
                                    background-size: cover; background-position: center; min-height: 200px;">
                            @if (string.IsNullOrEmpty(Model.FeaturedArticle.ImageUrl))
                            {
                                <i class="fa fa-landmark"
                                   style="font-size:3rem;color:rgba(160,120,32,.3);position:relative;z-index:1;"></i>
                            }
                        </div>
                        <div class="codex-card-body">
                            <div class="codex-card-eyebrow">
                                Cover Story
                                @if (Model.FeaturedArticle.Sector != null)
                                {
                                    <span>&middot; @Model.FeaturedArticle.Sector.CategoryName</span>
                                }
                            </div>
                            <h3 class="codex-card-title">@Model.FeaturedArticle.Title</h3>
                            <div class="codex-card-meta">
                                @if (Model.FeaturedArticle.CreatedAt.HasValue)
                                {
                                    <span>
                                        <i class="fa fa-calendar me-1"></i>
                                        @Model.FeaturedArticle.CreatedAt.Value.ToString("dd MMM yyyy")
                                    </span>
                                }
                            </div>
                        </div>
                    </a>
                }

                @if (Model.SecondaryArticles != null && Model.SecondaryArticles.Any())
                {
                    <div class="row g-2">
                        @foreach (var article in Model.SecondaryArticles)
                        {
                            <div class="col-6">
                                <a href="/article/@article.Slug"
                                   class="codex-card p-3 d-block hero-secondary-card text-decoration-none">
                                    <div>
                                        @if (article.Sector != null)
                                        {
                                            <div class="codex-card-eyebrow" style="font-size:.52rem;">
                                                @article.Sector.CategoryName
                                            </div>
                                        }
                                        <div class="codex-card-title" style="font-size:.85rem;margin-top:.3rem;">
                                            @article.Title
                                        </div>
                                    </div>
                                    @if (!string.IsNullOrEmpty(article.ImageUrl))
                                    {
                                        <div class="mt-2"
                                             style="height:50px; background:url('@article.ImageUrl') center/cover no-repeat;
                                                    border-radius:2px; border:1px solid var(--border-lt);"></div>
                                    }
                                </a>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</section>

<!-- ══ TICKER ══════════════════════════════════════════════ -->
@if (Model.LatestArticles != null && Model.LatestArticles.Any())
{
    <div style="background:var(--parch-2);border-top:1px solid var(--border-lt);border-bottom:1px solid var(--border-lt);padding:.48rem 0;overflow:hidden;">
        <div class="container">
            <div class="d-flex align-items-center gap-3">
                <span style="font-family:var(--font-display);font-size:.56rem;letter-spacing:.2em;text-transform:uppercase;
                             background:var(--ink);color:var(--gold);padding:.28rem .85rem;
                             white-space:nowrap;border:1px solid var(--ink-3);flex-shrink:0;">
                    Latest Dispatches
                </span>
                <div class="ticker-track"
                     style="font-family:var(--font-display);font-size:.65rem;letter-spacing:.1em;
                            text-transform:uppercase;color:var(--ink-3);white-space:nowrap;">
                    @foreach (var a in Model.LatestArticles.Concat(Model.LatestArticles))
                    {
                        <span>@a.Title</span>
                        <span style="margin:0 1.5em;color:var(--border);">&middot;</span>
                    }
                </div>
            </div>
        </div>
    </div>
}

<!-- ══ LATEST ARTICLES ══════════════════════════════════════ -->
<section id="latest-articles" class="section bg-parch">
    <div class="container">
        <div class="chapter-header reveal">
            <span class="eyebrow">Fresh from the Archives</span>
            <h2 class="section-title">Latest Articles</h2>
            <div class="rule-triple"></div>
        </div>

        <div class="d-flex flex-wrap justify-content-center gap-2 mb-4 reveal">
            <button class="btn-codex active" style="font-size:.62rem;padding:.35rem 1.1rem;"
                    onclick="window.location.href='/articles'">
                All Articles
            </button>
            @foreach (var cat in Model.Categories)
            {
                <button class="btn-codex parch" style="font-size:.62rem;padding:.35rem 1.1rem;"
                        onclick="redirectToCategory('@cat.Category.CategorySlug')">
                    @cat.Category.CategoryName
                </button>
            }
        </div>

        <div class="row g-4" id="articleGrid">
            @if (Model.LatestArticles == null || !Model.LatestArticles.Any())
            {
                <div class="col-12 text-center py-5">No articles published yet.</div>
            }
            else
            {
                int idx = 0;
                foreach (var article in Model.LatestArticles.Take(6))
                {
                    idx++;
                    <div class="col-md-6 col-lg-4 reveal d@((idx % 3) + 1) article-search-item">
                        <article class="article-card h-100"
                                 onclick="window.location.href='/article/@article.Slug'"
                                 style="cursor:pointer;">
                            <div class="article-card-img"
                                 style="background: @(string.IsNullOrEmpty(article.ImageUrl)
                                     ? "linear-gradient(135deg,var(--ink-2),var(--ink))"
                                     : $"url('{article.ImageUrl}') center/cover no-repeat");
                                        min-height: 180px;">
                                @if (string.IsNullOrEmpty(article.ImageUrl))
                                {
                                    <i class="fa fa-landmark"
                                       style="font-size:2rem;color:rgba(160,120,32,.22);"></i>
                                }
                                @if (article.Sector != null)
                                {
                                    <span class="era-badge">@article.Sector.CategoryName</span>
                                }
                            </div>
                            <div class="article-card-body">
                                <h3 class="article-card-title">@article.Title</h3>
                                <p class="article-card-excerpt">@article.ShortBio</p>
                            </div>
                        </article>
                    </div>
                }
            }
        </div>
    </div>
</section>

@section Scripts {
    <script>
        // Hero date — Home page only
        var heroDateEl = document.getElementById('heroDate');
        if (heroDateEl) {
            var opts = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' };
            heroDateEl.textContent = new Date().toLocaleDateString('en-US', opts).toUpperCase();
        }

        // Ticker speed — Home page only
        var ticker = document.querySelector('.ticker-track');
        if (ticker) {
            ticker.style.animationDuration = (ticker.offsetWidth / 50) + 's';
        }

        // Scroll reveal — Home page only
        function revealOnScroll() {
            document.querySelectorAll('.reveal').forEach(function (el) {
                if (el.getBoundingClientRect().top < window.innerHeight - 100) {
                    el.classList.add('active');
                }
            });
        }
        window.addEventListener('scroll', revealOnScroll);
        revealOnScroll();
    </script>
}
