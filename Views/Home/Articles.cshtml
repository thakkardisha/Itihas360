@model Itihas360.Models.HomeViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";

    var searchParam = Context.Request.Query["search"].ToString();
    var categoryParam = Context.Request.Query["category"].ToString();

    string pageHeading = "The Archives";
    if (!string.IsNullOrEmpty(categoryParam))
    {
        var matchedCat = Model.Categories.FirstOrDefault(c =>
            c.Category.CategorySlug.Equals(categoryParam, StringComparison.OrdinalIgnoreCase));
        pageHeading = matchedCat != null ? matchedCat.Category.CategoryName : "Category Collection";
    }
    else if (!string.IsNullOrEmpty(searchParam))
    {
        pageHeading = $"Search: \"{searchParam}\"";
    }

    ViewData["Title"] = pageHeading + " — Itihas 360";
    ViewData["ActivePage"] = "Articles";  

    // Articles page uses RecentNotifications for the bell panel
    ViewBag.LatestArticles = Model.RecentNotifications;
}
@section HeadStyles {
}

@*
    NOTE: The layout renders the standard nav-search-btn + bell.
    On Articles we want an inline search form + bell instead.
    Since ASP.NET MVC layouts don't support overriding partial nav slots,
    we hide the layout's search button and inject our own via CSS+JS below.
*@

<header class="py-5 text-center bg-dark text-white position-relative"
        style="background: linear-gradient(rgba(38,22,5,0.85), rgba(38,22,5,0.95)),
               url('/uploads/articles/default.jpg') center/cover no-repeat;
               border-bottom: 2px solid var(--gold);">
    <div class="container py-4">
        <span class="eyebrow text-uppercase tracking-wider"
              style="color:var(--gold);font-size:0.75rem;letter-spacing:0.2em;">
            Article Directory
        </span>
        <h1 class="display-5 text-uppercase mt-2"
            style="font-family:var(--font-display);font-weight:700;color:#fff;">
            @pageHeading
        </h1>
        <div class="rule-triple my-3 mx-auto" style="width:80px;"></div>
    </div>
</header>

<main class="py-5">
    <div class="container">

        @if (Model.LatestArticles == null || !Model.LatestArticles.Any())
        {
            <div class="text-center py-5 rounded my-4"
                 style="background:var(--parch-2);border:1px dashed var(--border);">
                <i class="fa fa-folder-open mb-3 opacity-50"
                   style="font-size:3rem;color:var(--ink);"></i>
                <h3 style="font-family:var(--font-display);color:var(--ink);">
                    No Matching Dispatches Found
                </h3>
                <p class="text-muted small mx-auto" style="max-width:500px;">
                    We couldn't find any historical items matching your query.
                    Try searching another era or review your filters.
                </p>
                <a href="/articles"
                   class="btn-codex crimson-btn mt-3 d-inline-block text-decoration-none"
                   style="background-color:var(--ink);color:#fff;padding:0.5rem 1.5rem;border-radius:4px;">
                    <i class="fa fa-rotate-left me-2"></i> Clear Filters &amp; View All
                </a>
            </div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var article in Model.LatestArticles)
                {
                    <div class="col-md-6 col-lg-4">
                        <article class="article-card h-100"
                                 onclick="window.location.href='/article/@article.Slug'"
                                 style="cursor:pointer;">
                            <div class="article-card-img"
                                 style="background: @(string.IsNullOrEmpty(article.ImageUrl)
                                     ? "linear-gradient(135deg,var(--ink-2),var(--ink))"
                                     : $"url('{article.ImageUrl}') center/cover no-repeat");
                                        min-height:200px; position:relative;">
                                @if (string.IsNullOrEmpty(article.ImageUrl))
                                {
                                    <i class="fa fa-landmark"
                                       style="font-size:2rem;color:rgba(160,120,32,.22);"></i>
                                }
                                @if (article.Sector != null)
                                {
                                    <span class="era-badge">@article.Sector.CategoryName</span>
                                }
                            </div>
                            <div class="article-card-body p-4 bg-white"
                                 style="border:1px solid var(--border-lt);border-top:0;">
                                <h3 class="article-card-title h5"
                                    style="font-family:var(--font-display);font-weight:600;color:var(--ink);">
                                    @article.Title
                                </h3>
                                <p class="article-card-excerpt small text-muted mt-2">@article.ShortBio</p>
                            </div>
                        </article>
                    </div>
                }
            </div>
        }
    </div>
</main>

@section Scripts {
    <script>
        // On the Articles page: hide the layout's "Search" button and show inline search in nav instead
        // The layout's nav already has the bell; we just suppress the overlay-search btn here.
        // var searchBtn = document.getElementById('searchOpenTrigger');
        // if (searchBtn) searchBtn.style.display = 'none';
    </script>
}