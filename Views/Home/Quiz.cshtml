@model List<Itihas360.Models.Mcqquestion>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Historical Examination — Itihas 360";
    ViewData["ActivePage"] = "Quiz";
    var categories = ViewBag.Categories as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
}

@section HeadStyles {
    <style>
        /* ... Keep your existing CSS exactly as it is ... */
        .pagination .page-link {
            background-color: var(--parch-2);
            border: 1px solid var(--parch-3);
            color: var(--ink);
            font-family: 'Cinzel', serif;
            margin: 0 5px;
            border-radius: 0;
        }

        .pagination .page-item.active .page-link {
            background-color: var(--ink);
            color: var(--parch-1);
            border-color: var(--ink);
        }
    </style>
}

<div class="container">
    <div class="quiz-master-container">
        <header class="text-center mb-4">
            <h1 class="quiz-page-title mb-3"><i class="fa-solid fa-graduation-cap me-2" style="color: var(--gold);"></i>Test your knowledge</h1>
            <hr style="border-color: var(--parch-3); opacity: 0.6; margin: 1.5rem auto; width: 40%;">
        </header>

        @if (Model != null && Model.Any() && categories.Any())
        {
            <div class="filter-btn-container">
                <button type="button" class="btn btn-filter active" data-quiz-filter="all">All Fields</button>
                @foreach (var cat in categories)
                {
                    <button type="button" class="btn btn-filter" data-quiz-filter="@cat.Category.CategoryId">@cat.Category.CategoryName</button>
                }
            </div>
        }

        <div id="quizForm">
            <div id="quizContainer">
                @if (Model != null && Model.Any())
                {
                    foreach (var q in Model)
                    {
                        <div class="quiz-card structural-card-node d-none"
                             data-question-block="@q.QuestionId"
                             data-category="@(q.SectorId ?? 0)"
                             data-is-answered="false">
                            <h5 class="mb-4 fw-bold question-text-heading" style="font-family:'Cinzel', serif; line-height: 1.4;">
                                <span class="question-index-number" style="color:var(--gold);"></span> @q.QuestionText
                            </h5>
                            <div class="options-group">
                                @if (q.Mcqoptions != null)
                                {
                                    foreach (var opt in q.Mcqoptions.OrderBy(o => o.OptionLabel))
                                    {
                                        <div class="option-row" data-option-id="@opt.OptionId" data-correct-check="@(opt.IsCorrect == true ? "true" : "false")" onclick="window.handleInlineSelection(this)">
                                            <div class="d-flex align-items-center w-100">
                                                <div class="quiz-custom-radio"></div>
                                                <span><strong>@opt.OptionLabel.</strong> @opt.OptionText</span>
                                            </div>
                                            <div class="status-icon-holder"></div>
                                        </div>
                                    }
                                }
                            </div>
                            @if (!string.IsNullOrWhiteSpace(q.ExplanationText))
                            {
                                <div id="explain_@q.QuestionId" class="explanation-box d-none">
                                    <div class="text-uppercase fw-bold text-muted small mb-1" style="letter-spacing: 0.1em; font-size: 0.7rem; color: var(--gold) !important;">Explanation:</div>
                                    <div>@q.ExplanationText</div>
                                </div>
                            }
                        </div>
                    }
                }
            </div>

            <div id="quizEmptyState" class="p-5 text-center d-none opacity-75">
                <p>No active questions for this category yet.</p>
            </div>

            <nav id="quizPagination" class="mt-4"><ul class="pagination justify-content-center" id="paginationList"></ul></nav>

            <div id="resetButtonContainer" class="text-center mt-5">
                <button type="button" class="btn btn-chronicle-outline" onclick="window.resetHistoricalQuiz()"><i class="fa-solid fa-rotate-left me-2"></i> Reset</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            const questionsPerPage = 5;
            let currentPage = 1;

            function refreshQuestionNumbers() {
                let currentIdx = 1;
                $('.structural-card-node:visible').each(function () {
                    $(this).find('.question-index-number').text(currentIdx + ".");
                    currentIdx++;
                });
            }

            function updatePagination() {
                const allVisible = $('.structural-card-node:visible');
                const totalPages = Math.ceil(allVisible.length / questionsPerPage);
                const paginationList = $('#paginationList');
                paginationList.empty();
                if (totalPages <= 1) return;
                for (let i = 1; i <= totalPages; i++) {
                    paginationList.append(`<li class="page-item ${i === currentPage ? 'active' : ''}"><a class="page-link" href="#" onclick="window.changePage(${i}); return false;">${i}</a></li>`);
                }
            }

            window.changePage = function (pageNum) {
                currentPage = pageNum;
                const allVisible = $('.structural-card-node:visible');
                allVisible.addClass('d-none');
                allVisible.slice((pageNum - 1) * questionsPerPage, pageNum * questionsPerPage).removeClass('d-none');
                updatePagination();
                refreshQuestionNumbers();
                window.scrollTo({ top: $('#quizForm').offset().top - 100, behavior: 'smooth' });
            };

            // CATEGORY LIVE FILTER INTERACTION ENGINE
            $('[data-quiz-filter]').on('click', function () {
                $('[data-quiz-filter]').removeClass('active');
                $(this).addClass('active');

                const filter = $(this).attr('data-quiz-filter');

                // 1. Reset all cards: remove d-none to make them potentially visible,
                //    but hide them via jQuery .hide() so we can control them
                $('.structural-card-node').removeClass('d-none').hide();

                // 2. Select the correct subset
                const matches = (filter === 'all')
                    ? $('.structural-card-node')
                    : $(`.structural-card-node[data-category="${filter}"]`);

                // 3. Show only the matches
                matches.show();

                // 4. Update empty state visibility
                if (matches.length === 0) {
                    $('#quizEmptyState').removeClass('d-none');
                } else {
                    $('#quizEmptyState').addClass('d-none');
                }

                // 5. Reset to page 1
                currentPage = 1;
                window.changePage(1);
            });

            window.handleInlineSelection = function (el) {
                const card = el.closest('.structural-card-node');
                if (card.getAttribute('data-is-answered') === 'true') return;
                card.setAttribute('data-is-answered', 'true');
                const isCorrect = el.getAttribute('data-correct-check') === 'true';
                el.classList.add(isCorrect ? 'correct-selection' : 'incorrect-selection');
                el.querySelector('.status-icon-holder').innerHTML = isCorrect ? '<i class="fa fa-check-circle text-success fs-5"></i>' : '<i class="fa fa-times-circle text-danger fs-5"></i>';
                document.getElementById('explain_' + card.getAttribute('data-question-block'))?.classList.remove('d-none');
            };

            window.resetHistoricalQuiz = function () {
                $('.structural-card-node').attr('data-is-answered', 'false');
                $('.explanation-box').addClass('d-none');
                $('.option-row').removeClass('disabled correct-selection incorrect-selection');
                $('.status-icon-holder').html('');
                window.changePage(1);
            };

            window.changePage(1);
        });
    </script>
}