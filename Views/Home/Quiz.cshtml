@model List<Itihas360.Models.Mcqquestion>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Historical Examination — Itihas 360";
    ViewData["ActivePage"] = "Quiz";

    // Access the centrally managed layout categories mapped from your filter
    var categories = ViewBag.Categories as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
}

@section HeadStyles {
    <style>
        :root {
            --parch-1: #f2e8d0;
            --parch-2: #e8d9b5;
            --parch-3: #d9c490;
            --ink: #261605;
            --ink-2: #2d1f08;
            --ink-3: #3d2b0e;
            --gold: #a07820;
            --gold-bright: #c9960a;
            --success-accent: #2e5a1c;
            --error-accent: #8c251e;
        }

        body {
            background-color: var(--parch-1);
            color: var(--ink);
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.15rem;
        }

        .quiz-master-container {
            max-width: 900px;
            margin: 4rem auto;
            padding: 3.5rem;
            background-color: var(--parch-2);
            border: 1px solid var(--parch-3);
            box-shadow: 0 10px 30px rgba(38, 22, 5, 0.05);
            border-radius: 4px;
        }

        .quiz-page-title {
            font-family: 'Cinzel', serif;
            color: var(--ink);
            font-weight: 700;
            letter-spacing: 0.08em;
            text-transform: uppercase;
        }

        /* Category Filter Buttons Styling */
        .filter-btn-container {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 0.5rem;
            margin-bottom: 2.5rem;
        }

        .btn-filter {
            font-family: 'Cinzel', serif;
            font-size: 0.8rem;
            letter-spacing: 0.05em;
            text-transform: uppercase;
            background-color: transparent;
            color: var(--ink-3);
            border: 1px solid var(--parch-3);
            padding: 0.4rem 1.2rem;
            border-radius: 0;
            transition: all 0.2s ease;
        }

            .btn-filter:hover, .btn-filter.active {
                background-color: var(--ink);
                color: var(--parch-1);
                border-color: var(--ink);
            }

        .quiz-card {
            background-color: var(--parch-1);
            border: 1px solid var(--parch-3);
            border-radius: 0;
            padding: 2rem;
            margin-bottom: 2rem;
            transition: transform 0.2s ease;
        }

        .option-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0.75rem 1rem;
            border: 1px solid transparent;
            margin-bottom: 0.65rem;
            cursor: pointer;
            transition: all 0.2s ease;
            background-color: transparent;
        }

            .option-row:hover:not(.disabled) {
                background-color: rgba(160, 120, 32, 0.08);
                border-color: var(--parch-3);
            }

            .option-row.disabled {
                cursor: not-allowed;
            }

        .quiz-custom-radio {
            width: 16px;
            height: 16px;
            border: 1px solid var(--ink-3);
            border-radius: 50%;
            margin-right: 12px;
            flex-shrink: 0;
            position: relative;
            transition: all 0.2s ease;
        }

        .option-row:hover:not(.disabled) .quiz-custom-radio {
            border-color: var(--gold);
        }

        .option-row.correct-selection {
            background-color: rgba(46, 90, 28, 0.12) !important;
            border: 1px solid var(--success-accent) !important;
            color: var(--success-accent);
        }

            .option-row.correct-selection .quiz-custom-radio {
                border-color: var(--success-accent);
                background-color: var(--success-accent);
            }

        .option-row.incorrect-selection {
            background-color: rgba(140, 37, 30, 0.1) !important;
            border: 1px solid var(--error-accent) !important;
            color: var(--error-accent);
        }

            .option-row.incorrect-selection .quiz-custom-radio {
                border-color: var(--error-accent);
                background-color: var(--error-accent);
            }

        .explanation-box {
            background-color: var(--parch-2);
            border-left: 3px solid var(--gold);
            padding: 1rem 1.25rem;
            margin-top: 1.25rem;
            font-size: 1rem;
        }

        .btn-chronicle-outline {
            font-family: 'Cinzel', serif;
            color: var(--ink);
            background: transparent;
            border: 1px solid var(--ink-3);
            border-radius: 0;
            padding: 0.6rem 2rem;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            font-size: 0.9rem;
            font-weight: 600;
            transition: all 0.25s ease;
        }

            .btn-chronicle-outline:hover {
                color: var(--parch-1);
                background-color: var(--ink);
                border-color: var(--ink);
            }
    </style>
}

<div class="container">
    <div class="quiz-master-container">
        <header class="text-center mb-4">
            <h1 class="quiz-page-title mb-3">
                <i class="fa-solid fa-graduation-cap me-2" style="color: var(--gold);"></i>Test your knowledge
            </h1>
            <hr style="border-color: var(--parch-3); opacity: 0.6; margin: 1.5rem auto; width: 40%;">
        </header>

        @if (Model != null && Model.Any() && categories.Any())
        {
            <div class="filter-btn-container">
                <button type="button" class="btn btn-filter active" data-quiz-filter="all">All Fields</button>
                @foreach (var cat in categories)
                {
                    <button type="button" class="btn btn-filter" data-quiz-filter="@cat.Category.CategoryId">
                        @cat.Category.CategoryName
                    </button>
                }
            </div>
        }

        <div id="quizForm">
            @if (Model != null && Model.Any())
            {
                // Dynamic index counter handled smoothly via JavaScript to maintain order sequence when filtering
                foreach (var q in Model)
                {
                    <div class="quiz-card structural-card-node"
                         data-question-block="@q.QuestionId"
                         data-category="@(q.SectorId ?? 0)"
                         data-is-answered="false">

                        <h5 class="mb-4 fw-bold question-text-heading" style="font-family:'Cinzel', serif; line-height: 1.4;">
                            <span class="question-index-number" style="color:var(--gold);"></span> @q.QuestionText
                        </h5>

                        <div class="options-group">
                            @if (q.Mcqoptions != null)
                            {
                                foreach (var opt in q.Mcqoptions.OrderBy(o => o.OptionLabel))
                                {
                                    <div class="option-row"
                                         data-option-id="@opt.OptionId"
                                         data-correct-check="@(opt.IsCorrect == true ? "true" : "false")"
                                         onclick="window.handleInlineSelection(this)">

                                        <div class="d-flex align-items-center w-100">
                                            <div class="quiz-custom-radio"></div>
                                            <span>
                                                <strong>@opt.OptionLabel.</strong> @opt.OptionText
                                            </span>
                                        </div>
                                        <div class="status-icon-holder"></div>
                                    </div>
                                }
                            }
                        </div>

                        @if (!string.IsNullOrWhiteSpace(q.ExplanationText))
                        {
                            <div id="explain_@q.QuestionId" class="explanation-box d-none">
                                <div class="text-uppercase fw-bold text-muted small mb-1" style="letter-spacing: 0.1em; font-size: 0.7rem; color: var(--gold) !important;">Explanation:</div>
                                <div>@q.ExplanationText</div>
                            </div>
                        }
                    </div>
                }

                <div id="quizEmptyState" class="p-5 text-center d-none opacity-75">
                    <i class="fa-regular fa-folder-open mb-3 d-block" style="font-size:2.5rem; color:var(--gold);"></i>
                    <p class="mb-0 font-display text-uppercase" style="font-family:'Cinzel',serif; letter-spacing: 0.1em;">No active questions for this category yet.</p>
                </div>

                <div id="resetButtonContainer" class="text-center mt-5">
                    <button type="button" class="btn btn-chronicle-outline" onclick="window.resetHistoricalQuiz()">
                        <i class="fa-solid fa-rotate-left me-2"></i> Reset
                    </button>
                </div>
            }
            else
            {
                <div class="p-5 text-center bg-transparent border-0 opacity-75">
                    <i class="fa-regular fa-folder-open mb-3 d-block" style="font-size:2.5rem; color:var(--gold);"></i>
                    <p class="mb-0 font-display text-uppercase" style="font-family:'Cinzel',serif; letter-spacing: 0.1em;">No standard examinations are active at this coordinate.</p>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {

            // Re-indexes only visible questions dynamically (e.g. 1, 2, 3 instead of jumping numbers)
            function refreshQuestionNumbers() {
                let currentIdx = 1;
                $('.structural-card-node:visible').each(function () {
                    $(this).find('.question-index-number').text(currentIdx + ".");
                    currentIdx++;
                });
            }

            // Initial question numbering call
            refreshQuestionNumbers();

            // ═════════════════════════════════════════════════════════════
            // CATEGORY LIVE FILTER INTERACTION ENGINE
            // ═════════════════════════════════════════════════════════════
            $('[data-quiz-filter]').on('click', function () {
                const targetFilter = $(this).attr('data-quiz-filter');

                // Toggle active link states cleanly
                $('[data-quiz-filter]').removeClass('active');
                $(this).addClass('active');

                if (targetFilter === 'all') {
                    $('.structural-card-node').fadeIn(300);
                    $('#quizEmptyState').addClass('d-none');
                    $('#resetButtonContainer').removeClass('d-none');
                } else {
                    $('.structural-card-node').hide();

                    const matches = $(`.structural-card-node[data-category="${targetFilter}"]`);
                    if (matches.length > 0) {
                        matches.fadeIn(300);
                        $('#quizEmptyState').addClass('d-none');
                        $('#resetButtonContainer').removeClass('d-none');
                    } else {
                        $('#quizEmptyState').removeClass('d-none');
                        $('#resetButtonContainer').addClass('d-none'); // Hide reset button if empty
                    }
                }

                // Wait for step fading tracking animations to settle, then adjust order indicators
                setTimeout(refreshQuestionNumbers, 305);
            });


            window.handleInlineSelection = function (selectedElement) {
                const currentCard = selectedElement.closest('.structural-card-node');

                if (currentCard.getAttribute('data-is-answered') === 'true') {
                    return;
                }

                currentCard.setAttribute('data-is-answered', 'true');

                const totalOptions = currentCard.querySelectorAll('.option-row');
                const isTargetCorrect = selectedElement.getAttribute('data-correct-check') === 'true';
                const questionId = currentCard.getAttribute('data-question-block');

                totalOptions.forEach(opt => {
                    opt.classList.add('disabled');

                    if (opt.getAttribute('data-correct-check') === 'true') {
                        opt.classList.add('correct-selection');
                        opt.querySelector('.status-icon-holder').innerHTML = '<i class="fa fa-check-circle text-success fs-5"></i>';
                    }
                });

                if (!isTargetCorrect) {
                    selectedElement.classList.add('incorrect-selection');
                    selectedElement.querySelector('.status-icon-holder').innerHTML = '<i class="fa fa-times-circle text-danger fs-5"></i>';
                }

                const explanationBox = document.getElementById('explain_' + questionId);
                if (explanationBox) {
                    explanationBox.classList.remove('d-none');
                }
            };

            window.resetHistoricalQuiz = function () {
                const quizCards = document.querySelectorAll('.structural-card-node');

                quizCards.forEach(card => {
                    card.setAttribute('data-is-answered', 'false');

                    const qId = card.getAttribute('data-question-block');
                    const explanationBox = document.getElementById('explain_' + qId);
                    if (explanationBox) {
                        explanationBox.classList.add('d-none');
                    }

                    const options = card.querySelectorAll('.option-row');
                    options.forEach(opt => {
                        opt.classList.remove('disabled', 'correct-selection', 'incorrect-selection');

                        const iconHolder = opt.querySelector('.status-icon-holder');
                        if (iconHolder) {
                            iconHolder.innerHTML = '';
                        }
                    });
                });

                window.scrollTo({
                    top: document.getElementById('quizForm').offsetTop - 40,
                    behavior: 'smooth'
                });
            };
        });
    </script>
}